#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// --- TOUS LES #DEFINE (Indispensables pour la structure) ---
#define TAILLE 5
#define MAX_NOM 50

#define MIROIR 3
#define TORCHE 4
#define HACHE 5
#define ARC 6 // on définit les monstres avec des nombres 

#define VICTOIRE 1
#define DEFAITE 0
#define RIEN 2

// --- STRUCTURES ---
typedef struct {
    char type;    // 'B' Basilic, 'Z' Zombie, 'T' Troll, 'H' Harpie, 'E' Epée, etc.
    int visible;  // 0 = cachée (brouillard), 1 = révélée
} Case;

typedef struct {
    int x, y;            // Position actuelle
    int x_dep, y_dep;    // Position de départ
    char nom[MAX_NOM];
    int classe;
    int a_trouve_coffre; // Au début = 0 pour tous les joueurs.
    int a_trouve_arme;   // Au début = 0.
    int nb_pas;          // Pour tes statistiques (Étudiant C)
} Joueur;

// --- FONCTIONS DE REMPLISSAGE (Étudiant A) ---

void remplir_cartes(char carte[25]){ // fonction pour décider quels personnages se trouvent dans le paquet de carte.
    int i;

    for(i = 0; i < 4; i++) { // on remplit les cases de 0 à 3
        carte[i]= 'B'; // 'B' correspond au monstre Basilic (il y en a 4)
    }

    for(i = 4; i < 8; i++){ // remplissage des 4 cases suivantes
        carte[i]= 'T'; // Correspond aux Trolls
    }

    for(i = 8; i < 12; i++) { // remplissage des 4 cases suivantes
        carte[i]= 'Z' ; // Zombies
    }

    for (i = 12; i < 16; i++){ // on remplit les 4 cases suivantes
        carte[i]='H'; // Correspond aux harpies
    }

    for(i = 16; i < 18; i++) { // les 2 cases suivantes pour les coffres
        carte[i]= 'C';
    }

    carte[18]='E'; // épée de feu (lettre B deja prise)
    carte[19]= 'F'; // baton familier
    carte[20]= 'D'; // dague du sommeil
    carte[21] = 'G'; // grimoire interdit
    carte[22]= 'P'; // portail magique
    carte[23]= 'M'; // totem de transmutation 
    carte[24]= 'M'; // totem de transmutation
}

void melanger_carte(char carte[], int n){ // mélange des cartes, on utilise void car c'est une action sans réponse

    for(int i = n - 1; i > 0; i--) { // on parcourt le tableau qu'on a créer depuis la fin

        int j = rand() % (i + 1); // tirage aléatoire, mélange efficacement les cartes

        char temp = carte[i];
        carte[i] = carte[j];
        carte[j] = temp; // échange des cartes sans détruire les données (chapitre tri)
    }
}

void remplir_plateau(char carte[25], Case plateau[5][5]) { // remplir plateau 5x5
    int a = 0; // va nous permettre de parcourir toutes les cartes 

    for (int i = 0; i < 5; i++){ // on parcourt les 5 cartes verticalement 
        for (int j = 0; j < 5; j++){ // on parcourt les 5 cartes horizontalement 

            plateau[i][j].type = carte[a]; // piocher une carte dans le tableau créer et la placer sur le plateau 
            plateau[i][j].visible = 0; // Initialisation du brouillard de guerre
            a++; // carte suivante
        }
    }
}

// --- LOGIQUE DE COMBAT ET CHOIX (Étudiant B) ---

int choisir_arme() { // choix de l'arme par l'utilisateur
    int choix; // variable qui va stocker le choix de l'utilisateur

    do {
        printf("Choisissez votre arme (3:Miroir, 4:Torche, 5:Hache, 6:Arc) : "); 

        if(scanf("%d", &choix) != 1) { // vérifie si l'entrée est bien un entier
            while(getchar() != '\n');// vérifie si l'entrée est bien un entier
            choix = 0; // verification du scanf
        }

        if(choix < 3 || choix > 6){ // vérifie si le nombre est hors limites
            printf("Nombre invalide !\n");
        }

    } while (choix < 3 || choix > 6); // continue tant que le choix n'est pas entre 3 et 6

    return choix; // renvoie le choix valide de l'utilisateur
}

int resoudre_combat(int arme, char monstre) { // logique combat

    if(monstre == 'B') { // si le monstre est un Basilic
        if(arme == MIROIR) { // si l'arme est le miroir
            printf("Victoire contre le Basilic\n");
            return VICTOIRE; // on renvoie victoire
        } else {
            printf("Pétrifié par le Basilic\n");
            return DEFAITE; // on renvoie défaite
        }
    }

    else if(monstre == 'Z') {  // si le monstre est un Zombie
        if(arme == TORCHE) { // la torche est efficace contre les zombies
            printf("Zombie vaincu\n");
            return VICTOIRE;
        } else {
            printf("Dévoré par le Zombie\n");
            return DEFAITE;
        }
    }

    else if(monstre == 'T') { // si le monstre est un Troll
        if(arme == HACHE) { // la hache est efficace contre le troll
            printf("Troll vaincu\n");
            return VICTOIRE;
        } else {
            printf("Troll vous tue\n");
            return DEFAITE;
        }
    }

    else if(monstre == 'H') { // si le monstre est une Harpie
        if(arme == ARC) { // l'arc est efficace contre la harpie
            printf("Harpie vaincue\n");
            return VICTOIRE;
        } else {
            printf("Harpie vous tue\n");
            return DEFAITE;
        }
    }

    return RIEN; // case vide ou objet
}

// --- AFFICHAGE (UI) ---

void afficher_plateau(Case plateau[TAILLE][TAILLE], Joueur *j_actuel) {
    printf("\n--- TOUR DE : %s ---\n", j_actuel->nom);
    printf("    0   1   2   3   4\n"); // Cette ligne sert uniquement à l'ergonomie
    for (int i = 0; i < TAILLE; i++) {
        printf("%d ", i); // Index de ligne
        for (int j = 0; j < TAILLE; j++) {
            // Si le joueur est sur la case, on affiche son icône 'P' (Pion)
            if (i == j_actuel->y && j == j_actuel->x) {
                printf("[ P ]"); 
            }
            // Sinon, si la case est révélée, on montre son contenu
            else if (plateau[i][j].visible == 1) {
                printf("[ %c ]", plateau[i][j].type);
            }
            // Sinon, c'est le brouillard de guerre
            else {
                printf("[ ? ]");
            }
        }
        printf("\n");
    }
}

// --- BOUCLE PRINCIPALE (Étudiant C) ---

int main() {
    srand(time(NULL));
    char recommencer;

    do {
        Case plateau[TAILLE][TAILLE];
        char cartes[25];
        int nb_joueurs;
        Joueur tab_j[4];

        printf("=== BIENVENUE DANS LE MEMO-RPG ===\n");
        do {
            printf("Combien de joueurs (2 a 4) ? ");
            if(scanf("%d", &nb_joueurs) != 1) {
                while(getchar() != '\n');
                nb_joueurs = 0;
            }
        } while (nb_joueurs < 2 || nb_joueurs > 4);

        for (int i = 0; i < nb_joueurs; i++) {
            printf("\nNom Joueur %d : ", i + 1);
            scanf("%s", tab_j[i].nom);
            printf("Classe (0:Guerrier, 1:Ranger, 2:Mage, 3:Voleur) : ");
            scanf("%d", &tab_j[i].classe);
            tab_j[i].a_trouve_coffre = 0;
            tab_j[i].a_trouve_arme = 0;
            tab_j[i].nb_pas = 0;
        }

        // Initialisation des positions (Symétrie Radiale)
        int depX[4] = {2, 2, 0, 4};
        int depY[4] = {0, 4, 2, 2};
        for(int i=0; i<nb_joueurs; i++) {
            tab_j[i].x = depX[i]; tab_j[i].y = depY[i];
            tab_j[i].x_dep = depX[i]; tab_j[i].y_dep = depY[i];
        }

        remplir_cartes(cartes);
        melanger_carte(cartes, 25);
        remplir_plateau(cartes, plateau);

        int fini = 0;
        while (!fini) {
            for (int i = 0; i < nb_joueurs && !fini; i++) {
                afficher_plateau(plateau, &tab_j[i]);
                
                int arme_choisie = choisir_arme();

                char dir;
                printf("Deplacement (Z:Haut, S:Bas, Q:Gauche, D:Droite) : ");
                scanf(" %c", &dir); // L'espace avant %c est CRUCIAL

                int nx = tab_j[i].x, ny = tab_j[i].y;
                if(dir=='z'||dir=='Z') ny--;
                else if(dir=='s'||dir=='S') ny++;
                else if(dir=='q'||dir=='Q') nx--;
                else if(dir=='d'||dir=='D') nx++;

                // Vérifier limites du plateau
                if (nx < 0 || nx >= 5 || ny < 0 || ny >= 5) {
                    printf("Mur ! Impossible d'aller par la.\n");
                } else {
                    tab_j[i].x = nx; tab_j[i].y = ny;
                    tab_j[i].nb_pas++;
                    plateau[ny][nx].visible = 1; // On révèle la case

                    char type_case = plateau[ny][nx].type;
                    
                    // Gestion des combats
                    if(type_case == 'B' || type_case == 'Z' || type_case == 'T' || type_case == 'H') {
                        if(resoudre_combat(arme_choisie, type_case) == DEFAITE) {
                            printf("Vous repartez au debut...\n");
                            tab_j[i].x = tab_j[i].x_dep;
                            tab_j[i].y = tab_j[i].y_dep;
                            // On remet tout face cachée après une défaite (selon le sujet)
                            for(int r=0; r<5; r++) for(int c=0; c<5; c++) plateau[r][c].visible = 0;
                        }
                    } 
                    // Gestion des objets
                    else if(type_case == 'C') {
                        printf("Coffre trouve !\n");
                        tab_j[i].a_trouve_coffre = 1;
                    } 
                    else if((type_case=='E'&&tab_j[i].classe==0) || (type_case=='F'&&tab_j[i].classe==1) || 
                            (type_case=='G'&&tab_j[i].classe==2) || (type_case=='D'&&tab_j[i].classe==3)) {
                        printf("Arme antique trouvee !\n");
                        tab_j[i].a_trouve_arme = 1;
                    }

                    // Vérification Victoire
                    if(tab_j[i].a_trouve_coffre && tab_j[i].a_trouve_arme) {
                        printf("\n******************************************\n");
                        printf("   VICTOIRE TOTALE POUR %s !\n", tab_j[i].nom);
                        printf("******************************************\n");
                        fini = 1;
                    }
                }
            }
        }

        printf("Voulez-vous rejouer une partie (O/N) ? ");
        scanf(" %c", &recommencer);

    } while (recommencer == 'o' || recommencer == 'O');

    printf("Merci d'avoir joue ! A bientot.\n");
    return 0;
}
