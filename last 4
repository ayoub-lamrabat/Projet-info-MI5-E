// Efface l'écran du terminal (fonctionne sous Linux/Mac)
// On utilise un code ANSI : \033[2J efface tout, \033[H remet le curseur en haut
void effacer_ecran(void) {
    printf("\033[2J\033[H");
}

// Vide le buffer stdin pour éviter les résidus de saisie
// (les caractères non lus qui restent après un scanf)
void vider_buffer(void) {
    int c;
    while ((c = getchar()) != '\n' && c != EOF) {}
}

// Lit un nom au clavier de manière sécurisée :
// - taille limitée à MAX_NOM caractères (évite les dépassements)
// - ne peut pas être vide
// CORRECTION 3 : votre code utilisait scanf("%s") pour les noms, ce qui est
// dangereux (pas de limite de taille) et ne lit qu'un seul mot.
// On utilise fgets() à la place, comme dans votre fonction lire_nom().
void lire_nom(char nom[], char message[]) {
    int valide = 0;
    while (valide == 0) {
        printf("%s", message);
        if (fgets(nom, MAX_NOM, stdin) == NULL) {
            printf("Erreur de saisie.\n");
            continue;
        }
        // on supprime le '\n' final laissé par fgets
        if (nom[strlen(nom) - 1] == '\n') {
            nom[strlen(nom) - 1] = '\0';
        }
        // on vérifie que le nom n'est pas vide
        if (strlen(nom) > 0) {
            valide = 1;
        } else {
            printf("Erreur : le nom ne peut pas etre vide.\n");
        }
    }
}

// Lit un entier entre min et max de façon sécurisée.
// CORRECTION 4 : dans votre code, si on entrait une lettre à la place d'un
// nombre, le programme pouvait boucler infiniment. Cette fonction gère ça.
int lire_entier(char message[], int min, int max) {
    int valeur;
    printf("%s", message);
    while (scanf("%d", &valeur) != 1 || valeur < min || valeur > max) {
        vider_buffer();
        printf("Valeur invalide, entrez un nombre entre %d et %d : ", min, max);
    }
    vider_buffer(); // on consomme le '\n' restant
    return valeur;
}


