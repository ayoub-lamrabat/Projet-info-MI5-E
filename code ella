//1. Les Structures et le Moteur de Rendu (UI). Pour gérer le "brouillard de guerre", on ne peut pas juste utiliser un tableau de caractères. Il faut savoir si la case est révélée ou non.
// Dans fichier entites.h :
#define TAILLE 5
typedef struct {
    char type;           // 'B' Basilic, 'Z' Zombie, 'T' Troll, 'H' Harpie, 'E' Epée, 'F' Bâton, 'D' Dague, 'G' Grimoire, 'P' Portail, 'T' Totem, 'C' Coffre.
    int visible;         // 0 = cachée (brouillard), 1 = révélée
} Case;

typedef struct {
    int x, y;            // Position actuelle
    int x_dep, y_dep;    // Position de départ
    char nom[50];
    int classe;
    int a_trouve_coffre; // Au début = 0 pour tous les joueurs. Pendant le jeu, si un joueur tombe sur une case 'C' (Coffre), alors variable = 1.
    int a_trouve_arme;   // Au début = 0. Pendant le jeu, si le Guerrier tombe sur la case 'E' (Épée de feu), a_trouve_arme devient = 1.
} Joueur;



//La fonction d'affichage (dans affichage.c) : Elle parcourt le plateau. Si visible vaut 0, on affiche '?'.
void afficher_plateau(Case plateau[TAILLE][TAILLE], Joueur *j_actuel) {
    printf("\n--- TOUR DE : %s ---\n", j_actuel->nom);
    printf("   0   1   2   3   4\n"); // Cette ligne sert uniquement à l'ergonomie (pour aider le joueur). Comme c'est un jeu dans un terminal tout noir, le joueur a du mal à savoir sur quelle colonne il se trouve. En affichant les chiffres 0 1 2 3 4 tout en haut, tu crées une sorte de règle graduée. Si le pion est sous le 0, le joueur sait qu'il est à x = 0. Si le pion est sous le 4, il est tout à droite.
    for (int i = 0; i < TAILLE; i++) {
        printf("%d ", i); // Index de ligne
        for (int j = 0; j < TAILLE; j++) {
            // Si le joueur est sur la case, on affiche son icône 'P' (Pion)
            if (i == j_actuel->y && j == j_actuel->x) {
                printf("[ P ]"); // P pour Pion ou Personnage
            }
            // Sinon, si la case est révélée, on montre son contenu
            else if (plateau[i][j].visible == 1) {
                printf("[ %c ]", plateau[i][j].type);
            }
            // Sinon, c'est le brouillard de guerre
            else {
                printf("[ ? ]");
            }
        }
        printf("\n");
    }
}



//2. Moteur de déplacement et Symétrie Radiale.
//La symétrie radiale signifie que les joueurs partent des points cardinaux opposés. Initialisation des positions (dans moteur.c) :
//EST-CE QUE ces cases de couleur font partie du plateau de 5x5 ou sont-elles "en dehors" ?!!!!!

void init_positions_depart(Joueur tab_j[], int nb_joueurs) {
    // Joueur 0 (Case VERTE - Haut/Nord). Elle est au milieu (x=3) sur la ligne du haut (y=0)
    tab_j[0].x_dep = 3;
    tab_j[0].y_dep = 0;
   
    // Joueur 1 (Case ORANGE - Bas/Sud). Elle est au milieu (x=1) sur la ligne du bas (y=4)
    if (nb_joueurs > 1) {
        tab_j[1].x_dep = 1;
        tab_j[1].y_dep = 4;
    }
   
    // Joueur 2 (Case BLEUE - Gauche/Ouest). Elle est sur la colonne de gauche (x=0) au milieu de la hauteur (y=1)
    if (nb_joueurs > 2) {
        tab_j[2].x_dep = 0;
        tab_j[2].y_dep = 1;
    }
   
    // Joueur 3 (Case BLANCHE - Droite/Est). Elle est sur la colonne de droite (x=4) au milieu de la hauteur (y=3)
    if (nb_joueurs > 3) {
        tab_j[3].x_dep = 4;
        tab_j[3].y_dep = 3;
    }

    // Initialisation concrète : on place chaque joueur sur sa case de départ
    for(int i = 0; i < nb_joueurs; i++) {
        tab_j[i].x = tab_j[i].x_dep;
        tab_j[i].y = tab_j[i].y_dep;
       

    }
}



//3. Entrées sécurisées (ZQSD). Pour éviter que le programme ne plante si l'utilisateur tape "Bonjour" au lieu de 'Z', on vide le tampon.

char recuperer_direction() {
    char choix;
    int valide = 0;
    while (!valide) {
        printf("Deplacement (Z=Haut, S=Bas, Q=Gauche, D=Droite) : ");
        scanf(" %c", &choix); // (L'espace avant %c est CRUCIAL (ignore l'Entrée du tour précédent). JUSTIFICATION: Le problème : Le "Fantôme" de la touche Entrée. Quand tu demandes au joueur de taper une direction : Le joueur tape la lettre 'z'. Ensuite, il appuie sur la touche Entrée (le symbole \n en informatique) pour valider.Le souci, c'est que scanf récupère la lettre 'z', mais il laisse traîner le \n (le retour à la ligne) dans la mémoire tampon du clavier (le "buffer"). Au tour suivant : Quand ton programme arrive à nouveau sur un scanf("%c", &choix), il regarde le tampon. Il y voit le \n qui restait du tour d'avant. Il se dit : "Tiens, il y a déjà un caractère ici !". Il récupère donc le \n automatiquement sans attendre que le joueur tape quoi que ce soit. Résultat : Le programme affiche "Touche invalide" instantanément parce qu'il a cru que l'utilisateur avait tapé "Entrée" au lieu de Z, Q, S ou D. La solution : Le petit espace magique " %c".En mettant un espace juste avant le %c dans ton scanf, tu donnes une instruction très précise au langage C : "S'il te plaît, ignore tous les caractères 'blancs' (espaces, tabulations, et surtout les retours à la ligne \n) jusqu'à ce que tu trouves une vraie lettre ou un vrai chiffre." Voici ce qui se passe avec l'espace : Le \n du tour précédent est toujours là. Le scanf(" %c") arrive. Il voit le \n, il se dit : "C'est un caractère blanc, l'espace dans mon format me dit de l'ignorer". Il le jette à la poubelle.Il attend alors que l'utilisateur tape une nouvelle lettre).
       
        if (choix == 'z' || choix == 's' || choix == 'q' || choix == 'd' ||
            choix == 'Z' || choix == 'S' || choix == 'Q' || choix == 'D') {
            valide = 1;
        } else {
            printf("Touche invalide ! Recommencez.\n");
        }
    }
    return choix;
}



