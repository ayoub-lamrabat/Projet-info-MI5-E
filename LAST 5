void init_positions_depart(JoueurEnJeu tab_j[], int nb_joueurs) {
    // Positionnement des joueurs sur les 4 coins symétriques du plateau de jeu (5x5)
    tab_j[0].x_dep = 0; tab_j[0].y_dep = 0; // Coin Haut-Gauche
    if (nb_joueurs > 1) { tab_j[1].x_dep = 4; tab_j[1].y_dep = 4; } // Coin Bas-Droite
    if (nb_joueurs > 2) { tab_j[2].x_dep = 4; tab_j[2].y_dep = 0; } // Coin Haut-Droite
    if (nb_joueurs > 3) { tab_j[3].x_dep = 0; tab_j[3].y_dep = 4; } // Coin Bas-Gauche

    int i;
    for (i = 0; i < nb_joueurs; i++) {
        tab_j[i].x = tab_j[i].x_dep;
        tab_j[i].y = tab_j[i].y_dep;
    }
}


// ============================================================
