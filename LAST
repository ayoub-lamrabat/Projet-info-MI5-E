void init_positions_depart(JoueurEnJeu tab_j[], int nb_joueurs) {
    // Joueur 0 (Case VERTE - Haut/Nord)
    tab_j[0].x_dep = 2;
    tab_j[0].y_dep = 0;
   
    // Joueur 1 (Case ORANGE - Bas/Sud)
    if (nb_joueurs > 1) {
        tab_j[1].x_dep = 2;
        tab_j[1].y_dep = 4;
    }
   
    // Joueur 2 (Case BLEUE - Gauche/Ouest)
