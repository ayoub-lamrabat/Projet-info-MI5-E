void melanger_carte(int carte, int n) //void car c'est une action sans réponse
for(int i=n-1, i>0; i--){ // on parcourt depuis la fin le tableau de 25 qu'on a créer
int j = rand % (i+1); // va permetre de mélanger efficacement les cartes, pourquoi pas %25 comme d'habitude ? On pourrais piocher une carte deja placée a la fin, ca permet de ne plus toucher les cartes deja melangées 
int temp= carte[i]; 
carte[i]= carte[j];
carte[j]=temp;// cet échange de variable va permettre d'échanger la carte de base avec une carte choisit aléatoirement sans détruire les données (lié chap tri)
}// a noter qu'on uilise d'abord un tableau 1D parce que c'est plus simple a manipuler, (pr melanger un tableau 2D il faut gerer des paires de coordonnes, et en voulant placer les monstres sur le plateau risque detomber sur la meme case en tirant (devien loud )

