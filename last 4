                case 'M': printf(MAGENTA " To  " RESET); break;
                case 'P': printf(MAGENTA " Po  " RESET); break;
                default:  printf(" [?] "); break;
            }
            printf("|");
        }
        printf("\n");
        if (i < TAILLE - 1) {
            printf("      +");
            for (j = 0; j < TAILLE; j++) { printf("-----"); if (j < TAILLE-1) printf("+"); }
            printf("+\n");
        }
    }
    printf("      +");
    for (j = 0; j < TAILLE; j++) { printf("-----"); if (j < TAILLE-1) printf("+"); }
    printf("+\n\n");
}

void init_positions_depart(JoueurEnJeu tab_j[], int nb_joueurs) {
