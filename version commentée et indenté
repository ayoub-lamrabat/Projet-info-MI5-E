/*
 * remplir_cartes
 * Remplit le tableau carte[25] avec exactement les 25 cases du jeu,
 */
void remplir_cartes(char carte[25]) {
    int i;

    for (i = 0; i < 4; i++) {
        carte[i] = 'B'; // 4 Basilics  (indices 0 à 3)
    }
    for (i = 4; i < 8; i++) {
        carte[i] = 'T'; // 4 Trolls    (indices 4 à 7)
    }
    for (i = 8; i < 12; i++) {
        carte[i] = 'Z'; // 4 Zombies   (indices 8 à 11)
    }
    for (i = 12; i < 16; i++) {
        carte[i] = 'H'; // 4 Harpies   (indices 12 à 15)
    }
    for (i = 16; i < 18; i++) {
        carte[i] = 'C'; // 2 Coffres   (indices 16 à 17)
    }
    carte[18] = 'E'; // Épée de feu
    carte[19] = 'F'; // Bâton familier
    carte[20] = 'D'; // Dague du sommeil
    carte[21] = 'G'; // Grimoire interdit
    carte[22] = 'P'; // Portail magique
    carte[23] = 'M'; // Totem #1
    carte[24] = 'M'; // Totem #2
}

/*
 * melanger_carte
 * Mélange aléatoirement le tableau carte[] de taille n.
 */
void melanger_carte(char carte[], int n) {
    int i;

    for (i = n - 1; i > 0; i--) {
        int  j    = rand() % (i + 1); // Choisit un indice aléatoire entre 0 et i inclus
        char temp = carte[i];

        carte[i] = carte[j];
        carte[j] = temp;
    }
}

/*
 * remplir_plateau
 * Copie les 25 cartes (déjà mélangées) dans le tableau 2D plateau[5][5].
 * Toutes les cases sont initialisées à visible=0 (face cachée).
 */
void remplir_plateau(char carte[25], Case plateau[5][5]) {
    int a = 0, i, j; // 'a' est l'indice courant dans le tableau 1D des cartes

    for (i = 0; i < 5; i++) {
        for (j = 0; j < 5; j++) {
            plateau[i][j].type = carte[a++]; // Affecte la carte suivante à cette case
            plateau[i][j].visible = 0;       // Cachée au départ (brouillard de guerre)
        }
    }
}

/*
 * cacher_plateau
 * Remet toutes les cases du plateau en état "caché" (visible = 0).
 * Appelé quand un joueur perd un combat : tout le donjon redevient
 * mystérieux pour tout le monde.
 */
void cacher_plateau(Case plateau[5][5]) {
    int r, c;

    for (r = 0; r < 5; r++) {
        for (c = 0; c < 5; c++) {
            plateau[r][c].visible = 0;
        }
    }
}
