int choisir_arme(void) { // choix de l'arme par l'utilisateur
    int choix; // variable qui va stocker le choix de l'utilisateur

    printf(CYAN "\n  Choisissez votre arme :\n" RESET);
    // AMÉLIORATION AFFICHAGE : on présente les choix sur plusieurs lignes
    // avec des couleurs pour que ce soit plus lisible
    printf("  " JAUNE "[3]" RESET " Miroir    -> contre le Basilic\n");
    printf("  " JAUNE "[4]" RESET " Torche    -> contre le Zombie\n");
    printf("  " JAUNE "[5]" RESET " Hache     -> contre le Troll\n");
    printf("  " JAUNE "[6]" RESET " Arc       -> contre la Harpie\n");
    printf("  Votre choix : ");

    do {
        if (scanf("%d", &choix) != 1) { // vérifie si l'entrée est bien un entier
            while (getchar() != '\n'); // vérifie si l'entrée est bien un entier
            choix = 0;                 // verification du scanf
        }
        if (choix < 3 || choix > 6) { // vérifie si le nombre est hors limites
            printf(ROUGE "  Nombre invalide ! Entrez 3, 4, 5 ou 6 : " RESET);
        }
    } while (choix < 3 || choix > 6); // continue tant que le choix n'est pas entre 3 et 6

    return choix; // renvoie le choix valide de l'utilisateur
}

int resoudre_combat(int arme, char monstre) { // logique combat

    if (monstre == 'B') { // si le monstre est un Basilic
        if (arme == MIROIR) { // si l'arme est le miroir
            printf(VERT "  Victoire contre le Basilic !\n" RESET);
            return VICTOIRE; // on renvoie victoire
        } else {
            printf(ROUGE "  Petrifie par le Basilic... Il fallait le Miroir !\n" RESET);
            return DEFAITE; // on renvoie défaite
        }
    } else if (monstre == 'Z') { // si le monstre est un Zombie
        if (arme == TORCHE) { // la torche est efficace contre les zombies
            printf(VERT "  Zombie vaincu !\n" RESET);
            return VICTOIRE;
        } else {
            printf(ROUGE "  Devore par le Zombie... Il fallait la Torche !\n" RESET);
            return DEFAITE;
        }
    } else if (monstre == 'T') { // si le monstre est un Troll
        if (arme == HACHE) { // la hache est efficace contre le troll
            printf(VERT "  Troll vaincu !\n" RESET);
            return VICTOIRE;
        } else {
            printf(ROUGE "  Le Troll vous tue... Il fallait la Hache !\n" RESET);
            return DEFAITE;
        }
    } else if (monstre == 'H') { // si le monstre est une Harpie
        if (arme == ARC) { // l'arc est efficace contre la harpie
            printf(VERT "  Harpie vaincue !\n" RESET);
            return VICTOIRE;
        } else {
            printf(ROUGE "  La Harpie vous tue... Il fallait l'Arc !\n" RESET);
            return DEFAITE;
        }
    }

    return RIEN; // case vide ou objet
}

void logique_portail(int *joueur_x, int *joueur_y) { // fonction qui gère la téléportation du joueur via un portail
    printf(MAGENTA "  Portail Magique ! Choisissez une case cachee.\n" RESET);

    do { // boucle qui continue tant que les coordonnées sont invalides
        printf("  Nouvelle ligne (0-4) : "); // demande la nouvelle position en ligne
        if (scanf("%d", joueur_y) != 1) { vider_buffer(); *joueur_y = -1; }

        printf("  Nouvelle colonne (0-4) : "); // demande la nouvelle position en colonne
        if (scanf("%d", joueur_x) != 1) { vider_buffer(); *joueur_x = -1; }

        if (*joueur_x < 0 || *joueur_x > 4 || *joueur_y < 0 || *joueur_y > 4) {
            printf(ROUGE "  Coordonnees invalides !\n" RESET);
        }
    } while (*joueur_x < 0 || *joueur_x > 4 || *joueur_y < 0 || *joueur_y > 4); // vérifie que les coordonnées sont dans les limites du plateau (0 à 4)

    printf(MAGENTA "  Teleportation en [ligne %d][col %d] !\n" RESET, *joueur_y, *joueur_x); // la nouvelle position du joueur après téléportation
}

void logique_totem(Case plateau[5][5], int *x, int *y, int depx, int depy) {
    int cx, cy; // variables pour stocker les coordonnées de la case cible
    Case temp;  // variable temporaire pour l'échange

    printf(MAGENTA "  Totem de transmutation ! Choisissez une case a echanger.\n" RESET);

    // CORRECTION 5 : le totem n'avait pas de boucle de validation.
    // Si on entrait des coordonnées invalides, le programme continuait quand même.
    do {
        printf("  Ligne cible (0-4) : "); // demande la ligne de la case cible
        if (scanf("%d", &cy) != 1) { vider_buffer(); cy = -1; }

        printf("  Colonne cible (0-4) : "); // demande la colonne de la case cible
        if (scanf("%d", &cx) != 1) { vider_buffer(); cx = -1; }

        if (cx < 0 || cx > 4 || cy < 0 || cy > 4) {
            printf(ROUGE "  Coordonnees invalides !\n" RESET);
        }
    } while (cx < 0 || cx > 4 || cy < 0 || cy > 4);

    temp              = plateau[*y][*x];  // sauvegarde la valeur actuelle du joueur (Y d'abord pour ligne)
    plateau[*y][*x]   = plateau[cy][cx]; // échange la case du joueur avec la case cible
    plateau[cy][cx]   = temp;            // termine l'échange

    // la case échangée reste cachée (on ne révèle pas ce qu'il y avait)
    plateau[*y][*x].visible = 0;
    plateau[cy][cx].visible = 0;

    *x = depx; // remet la position du joueur à la position de départ en colonne
    *y = depy; // remet la position du joueur à la position de départ en ligne

    printf(MAGENTA "  Echange effectue ! Retour au depart.\n" RESET); // affiche la nouvelle position du joueur
}

int verifier_victoire(int *coffre, int *arme_trouvee, char case_actuelle, char arme_recherche) { // fonction qui vérifie les conditions de victoire

    if (case_actuelle == 'C') { // si la case actuelle contient un coffre
        printf(JAUNE "  Coffre trouve !\n" RESET);
        *coffre = 1; // on indique que le coffre a été trouvé
        if (*arme_trouvee == 0) printf("  Il vous manque encore votre arme antique...\n");
    }

    if (case_actuelle == arme_recherche) { // si c'est l'arme antique du joueur
        if      (case_actuelle == 'E') printf(VERT "  Epee de feu trouvee !\n" RESET);
        else if (case_actuelle == 'F') printf(VERT "  Baton familier trouve !\n" RESET);
        else if (case_actuelle == 'G') printf(VERT "  Grimoire interdit trouve !\n" RESET);
        else if (case_actuelle == 'D') printf(VERT "  Dague du sommeil trouvee !\n" RESET);
        *arme_trouvee = 1; // on retourne 1 pour signaler la victoire
        if (*coffre == 0) printf("  Il vous manque encore un coffre au tresor...\n");
    }

    // AJOUT : si c'est une arme antique mais pas la sienne, on l'indique
    if ((case_actuelle == 'E' || case_actuelle == 'F' ||
         case_actuelle == 'G' || case_actuelle == 'D') &&
         case_actuelle != arme_recherche) {
        printf(JAUNE "  Arme antique trouvee, mais ce n'est pas la votre !\n" RESET);
    }

    if (*coffre == 1 && *arme_trouvee == 1) {
        return 1; // VICTOIRE !
    }

    return 0; // sinon, la partie continue
}


