#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// --- TOUS LES #DEFINE ---
#define TAILLE 5
#define MAX_NOM 50

#define MIROIR 3
#define TORCHE 4
#define HACHE 5
#define ARC 6 // on définit les monstres avec des nombres 

#define VICTOIRE 1
#define DEFAITE 0
#define RIEN 2

// --- STRUCTURES ---
typedef struct {
    char type;    // 'B' Basilic, 'Z' Zombie, 'T' Troll, 'H' Harpie, 'E' Epée, etc.
    int visible;  // 0 = cachée (brouillard), 1 = révélée
} Case;

typedef struct {
    int x, y;            // Position actuelle
    int x_dep, y_dep;    // Position de départ
    char nom[MAX_NOM];
    int classe;
    int a_trouve_coffre; // Au début = 0 pour tous les joueurs.
    int a_trouve_arme;   // Au début = 0.
    int nb_pas;          // Pour tes statistiques (Étudiant C)
    int actif;           // 1 = en jeu, 0 = a quitté
} Joueur;

// --- FONCTIONS DE REMPLISSAGE (Étudiant A) ---

void remplir_cartes(char carte[25]){ // fonction pour décider quels personnages se trouvent dans le paquet de carte.
    int i;
    for(i = 0; i < 4; i++) { // on remplit les cases de 0 à 3
        carte[i]= 'B'; // 'B' correspond au monstre Basilic (il y en a 4)
    }
    for(i = 4; i < 8; i++){ // remplissage des 4 cases suivantes
        carte[i]= 'T'; // Correspond aux Trolls
    }
    for(i = 8; i < 12; i++) { // remplissage des 4 cases suivantes
        carte[i]= 'Z' ; // Zombies
    }
    for (i = 12; i < 16; i++){ // on remplit les 4 cases suivantes
        carte[i]='H'; // Correspond aux harpies
    }
    for(i = 16; i < 18; i++) { // les 2 cases suivantes pour les coffres
        carte[i]= 'C';
    }
    carte[18]='E'; // épée de feu (lettre B deja prise)
    carte[19]= 'F'; // baton familier
    carte[20]= 'D'; // dague du sommeil
    carte[21] = 'G'; // grimoire interdit
    carte[22]= 'P'; // portail magique
    carte[23]= 'M'; // totem de transmutation 
    carte[24]= 'M'; // totem de transmutation
}

void melanger_carte(char carte[], int n){ // mélange des cartes, on utilise void car c'est une action sans réponse
    for(int i = n - 1; i > 0; i--) { // on parcourt le tableau qu'on a créer depuis la fin
        int j = rand() % (i + 1); // tirage aléatoire, mélange efficacement les cartes
        char temp = carte[i];
        carte[i] = carte[j];
        carte[j] = temp; // échange des cartes sans détruire les données (chapitre tri)
    }
}

void remplir_plateau(char carte[25], Case plateau[5][5]) { // remplir plateau 5x5
    int a = 0; // va nous permettre de parcourir toutes les cartes 
    for (int i = 0; i < 5; i++){ // on parcourt les 5 cartes verticalement 
        for (int j = 0; j < 5; j++){ // on parcourt les 5 cartes horizontalement 
            plateau[i][j].type = carte[a]; // piocher une carte dans le tableau créer et la placer sur le plateau 
            plateau[i][j].visible = 0; // Initialisation du brouillard de guerre
            a++; // carte suivante
        }
    }
}

// --- LOGIQUE DE COMBAT ET CHOIX (Étudiant B) ---

int choisir_arme() { // choix de l'arme par l'utilisateur
    int choix; // variable qui va stocker le choix de l'utilisateur
    do {
        printf("Choisissez votre arme (3:Miroir, 4:Torche, 5:Hache, 6:Arc) : "); 
        if(scanf("%d", &choix) != 1) { 
            while(getchar() != '\n');
            choix = 0; 
        }
        if(choix < 3 || choix > 6) printf("Nombre invalide !\n");
    } while (choix < 3 || choix > 6); 
    return choix; 
}

int resoudre_combat(int arme, char monstre) { // logique combat
    if(monstre == 'B') { 
        if(arme == MIROIR) { printf("Victoire contre le Basilic\n"); return VICTOIRE; }
        else { printf("Pétrifié par le Basilic\n"); return DEFAITE; }
    }
    else if(monstre == 'Z') {  
        if(arme == TORCHE) { printf("Zombie vaincu\n"); return VICTOIRE; }
        else { printf("Dévoré par le Zombie\n"); return DEFAITE; }
    }
    else if(monstre == 'T') { 
        if(arme == HACHE) { printf("Troll vaincu\n"); return VICTOIRE; }
        else { printf("Troll vous tue\n"); return DEFAITE; }
    }
    else if(monstre == 'H') { 
        if(arme == ARC) { printf("Harpie vaincue\n"); return VICTOIRE; }
        else { printf("Harpie vous tue\n"); return DEFAITE; }
    }
    return RIEN; 
}

// --- AFFICHAGE (Étudiant B/C) ---

void afficher_plateau(Case plateau[TAILLE][TAILLE], Joueur *j_actuel) {
    printf("\n    0   1   2   3   4\n"); 
    for (int i = 0; i < TAILLE; i++) {
        printf("%d ", i); 
        for (int j = 0; j < TAILLE; j++) {
            if (i == j_actuel->y && j == j_actuel->x) printf("[ P ]"); 
            else if (plateau[i][j].visible == 1) printf("[ %c ]", plateau[i][j].type);
            else printf("[ ? ]");
        }
        printf("\n");
    }
}

// --- MAIN BIEN STRUCTURE ---

int main() {
    srand(time(NULL));
    Case plateau[TAILLE][TAILLE];
    char cartes[25];
    int nb_joueurs, en_lice, fini = 0;
    Joueur tab_j[4];

    printf("=== BIENVENUE DANS LE MEMO-RPG ===\n");
    do {
        printf("Nombre de joueurs (2-4) : ");
        scanf("%d", &nb_joueurs);
    } while (nb_joueurs < 2 || nb_joueurs > 4);
    en_lice = nb_joueurs;

    int depX[4] = {2, 2, 0, 4}, depY[4] = {0, 4, 2, 2};

    for (int i = 0; i < nb_joueurs; i++) {
        printf("\nNom Joueur %d : ", i + 1); scanf("%s", tab_j[i].nom);
        printf("Classe (0:Guerrier, 1:Ranger, 2:Mage, 3:Voleur) : ");
        scanf("%d", &tab_j[i].classe);
        tab_j[i].x = depX[i]; tab_j[i].y = depY[i];
        tab_j[i].x_dep = depX[i]; tab_j[i].y_dep = depY[i];
        tab_j[i].a_trouve_coffre = 0; tab_j[i].a_trouve_arme = 0;
        tab_j[i].actif = 1;
    }

    remplir_cartes(cartes);
    melanger_carte(cartes, 25);
    remplir_plateau(cartes, plateau);

    while (!fini && en_lice > 0) {
        for (int i = 0; i < nb_joueurs && !fini; i++) {
            if (!tab_j[i].actif) continue;

            int tour_fini = 0;
            while (!tour_fini && !fini) {
                printf("\n--- TOUR DE %s ---", tab_j[i].nom);
                afficher_plateau(plateau, &tab_j[i]);
                
                printf("\n(A)vancer ou (Q)uitter la partie ? ");
                char action; scanf(" %c", &action);

                if (action == 'q' || action == 'Q') {
                    printf("%s quitte la partie.\n", tab_j[i].nom);
                    tab_j[i].actif = 0; en_lice--; tour_fini = 1;
                    continue;
                }

                int arme = choisir_arme();
                printf("Dir (Z,S,Q,D) : ");
                char dir; scanf(" %c", &dir);

                int nx = tab_j[i].x, ny = tab_j[i].y;
                if(dir=='z'||dir=='Z') ny--; else if(dir=='s'||dir=='S') ny++;
                else if(dir=='q'||dir=='Q') nx--; else if(dir=='d'||dir=='D') nx++;

                if (nx < 0 || nx >= 5 || ny < 0 || ny >= 5) {
                    printf("Mur ! Fin du tour.\n"); tour_fini = 1;
                } else {
                    tab_j[i].x = nx; tab_j[i].y = ny;
                    plateau[ny][nx].visible = 1;
                    char type = plateau[ny][nx].type;
                    printf("Case revelee : [ %c ]\n", type);

                    if (type == 'B' || type == 'Z' || type == 'T' || type == 'H') {
                        if (resoudre_combat(arme, type) == DEFAITE) {
                            tab_j[i].x = tab_j[i].x_dep; tab_j[i].y = tab_j[i].y_dep;
                            for(int r=0; r<5; r++) for(int c=0; c<5; c++) plateau[r][c].visible = 0;
                            tour_fini = 1;
                        }
                    } else if (type == 'C') {
                        tab_j[i].a_trouve_coffre = 1; printf("Coffre OK !\n");
                    } else if ((type=='E'&&tab_j[i].classe==0) || (type=='F'&&tab_j[i].classe==1) || 
                               (type=='D'&&tab_j[i].classe==2) || (type=='G'&&tab_j[i].classe==3)) {
                        tab_j[i].a_trouve_arme = 1; printf("Arme OK !\n");
                    } else {
                        tour_fini = 1;
                    }

                    if (tab_j[i].a_trouve_coffre && tab_j[i].a_trouve_arme) {
                        printf("\n%s GAGNE LA PARTIE !\n", tab_j[i].nom); fini = 1;
                    }
                }
            }
        }
    }
    return 0;
}
