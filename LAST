// --- FONCTIONS FICHIERS & HISTORIQUE (Étudiant C) ---

void vider_buffer(void) {
    int c;
    while ((c = getchar()) != '\n' && c != EOF){}
}

void lire_nom(char nom[], char message[]) {
    int valide = 0;
    while (valide == 0) {
        printf("%s", message);
        if (fgets(nom, MAX_NOM, stdin) == NULL) { 
            printf("Erreur de saisie.\n");
        }
        if (nom[strlen(nom) - 1] == '\n') {
            nom[strlen(nom) - 1] = '\0';
        }
        if (strlen(nom) > 0) {
            valide = 1;
        } else {
            printf("Erreur : le nom ne peut pas etre vide.\n");
        }
    }
}

void extraire_nom(char ligne[], char nom[]) {
    int i = 5, j = 0;
    while (ligne[i] != '\0' && ligne[i] != '\n') {
        nom[j++] = ligne[i++];
    }
    nom[j] = '\0';
}

int extraire_nombre(char ligne[]) {
    char texte_nombre[20];
    int i = 0, j = 0;
    while (ligne[i] != ':' && ligne[i] != '\0'){ i++; }
    if (ligne[i] == ':') i++;
    if (ligne[i] == ' ') i++;
    while (ligne[i] != '\0' && ligne[i] != '\n') {
        texte_nombre[j++] = ligne[i++];
    }
    texte_nombre[j] = '\0';
    return atoi(texte_nombre);
}

int lire_joueur_fichier(FILE *fichier, Joueur *joueur) {
    char ligne[100];
    if (fgets(ligne, 100, fichier) == NULL) return 0;
    extraire_nom(ligne, joueur->nom);

    if (fgets(ligne, 100, fichier) == NULL) return 0;
    joueur->parties = extraire_nombre(ligne);

    if (fgets(ligne, 100, fichier) == NULL) return 0;
    joueur->victoires = extraire_nombre(ligne);

    if (fgets(ligne, 100, fichier) == NULL) return 0;
    joueur->cases_parcourues = extraire_nombre(ligne);

    fgets(ligne, 100, fichier);
    return 1;
}

int chercher_joueur(Joueur joueurs[], int nb_joueurs, char nom[]) {
    for (int i = 0; i < nb_joueurs; i++) {
        if (strcmp(joueurs[i].nom, nom) == 0) {
            return i;
        }
    }
    return -1;
}

int ajouter_joueur(Joueur joueurs[], int *nb_joueurs, char nom[]) {
    int pos = chercher_joueur(joueurs, *nb_joueurs, nom);
    if (pos == -1) {
        if (*nb_joueurs < MAX_JOUEURS) {
            pos = *nb_joueurs;
            strncpy(joueurs[pos].nom, nom, MAX_NOM - 1);
            joueurs[pos].nom[MAX_NOM - 1] = '\0';
            joueurs[pos].parties = 0;
            joueurs[pos].victoires = 0;
            joueurs[pos].cases_parcourues = 0;
            (*nb_joueurs)++;
        } else {
            printf("Erreur : historique plein.\n");
        }
    }
    return pos;
}

int charger_historique(Joueur joueurs[]) {
    FILE *fichier = NULL;
    int nb_joueurs = 0;
    fichier = fopen("stats.txt", "r");
    if (fichier == NULL) {
        return 0;
    }
    while (nb_joueurs < MAX_JOUEURS && lire_joueur_fichier(fichier, &joueurs[nb_joueurs])) {
        nb_joueurs++;
    }
    fclose(fichier);
    return nb_joueurs;
}

void sauvegarder_historique(Joueur joueurs[], int nb_joueurs) {
    FILE *fichier = NULL;
    fichier = fopen("stats.txt", "w");
    if (fichier == NULL) {
        printf("Erreur : impossible d'ouvrir le fichier de sauvegarde.\n");
        return;
    }
    for (int i = 0; i < nb_joueurs; i++) {
        fprintf(fichier, "Nom: %s\n", joueurs[i].nom);
        fprintf(fichier, "Parties: %d\n", joueurs[i].parties);
        fprintf(fichier, "Victoires: %d\n", joueurs[i].victoires);
        fprintf(fichier, "Cases: %d\n", joueurs[i].cases_parcourues);
        fprintf(fichier, "---\n");
    }
    fclose(fichier);
}

void maj_historique(Joueur historique[], int *nb_historique, char noms_partie[][MAX_NOM], int nb_joueurs_partie, char gagnant[], int cases_partie[]) {
    for (int i = 0; i < nb_joueurs_partie; i++) {
        int position = ajouter_joueur(historique, nb_historique, noms_partie[i]);
        if (position != -1) {
            historique[position].parties++;
            historique[position].cases_parcourues += cases_partie[i];
            if (strcmp(noms_partie[i], gagnant) == 0) {
                historique[position].victoires++;
            }
        }
    }
}

int joueur_superieur(Joueur a, Joueur b) {
    if (a.victoires > b.victoires) return 1;
    if (a.victoires == b.victoires && a.parties < b.parties) return 1;
    if (a.victoires == b.victoires && a.parties == b.parties && a.cases_parcourues > b.cases_parcourues) return 1;
    return 0;
}

void trier_classement(Joueur joueurs[], int nb_joueurs) {
    for (int i = 0; i < nb_joueurs - 1; i++) {
        int meilleur = i;
        for (int j = i + 1; j < nb_joueurs; j++) {
            if (joueur_superieur(joueurs[j], joueurs[meilleur])) {
                meilleur = j;
            }
        }
        if (meilleur != i) {
            Joueur temp = joueurs[i];
            joueurs[i] = joueurs[meilleur];
            joueurs[meilleur] = temp;
        }
    }
}

void afficher_classement(Joueur historique[], int nb_historique) {
    if (nb_historique == 0) {
        printf("\nAucun joueur dans l'historique.\n");
        return;
    }
    trier_classement(historique, nb_historique);
    printf("\n======= CLASSEMENT GENERAL =======\n");
    for (int i = 0; i < nb_historique; i++) {
        printf("%d. %s (Victoires: %d | Parties: %d | Cases: %d)\n", 
               i + 1, historique[i].nom, historique[i].victoires, historique[i].parties, historique[i].cases_parcourues);
    }
    printf("==================================\n");
}

void afficher_resume_partie(char noms_partie[][MAX_NOM], int nb_joueurs_partie, char gagnant[], int cases_partie[]) {
    printf("\n========= RESUME DE PARTIE =========\n");
    printf("Gagnant : %s\n\n", (strlen(gagnant) > 0) ? gagnant : "Aucun (Abandon général)");
    printf("Joueurs de la partie :\n");
    for (int i = 0; i < nb_joueurs_partie; i++) {
        printf("- %s : %d cases parcourues\n", noms_partie[i], cases_partie[i]);
    }
    printf("====================================\n");
}

// --- BOUCLE PRINCIPALE LOGIQUE ---

int main() {
    srand(time(NULL));
    
    Joueur historique[MAX_JOUEURS];
    int nb_historique = charger_historique(historique);

    Case plateau[TAILLE][TAILLE];
    char cartes[25];
    int nb_joueurs, en_lice;
    JoueurEnJeu tab_j[4];
    int fini = 0;
    char gagnant_nom[MAX_NOM] = "";
    
    time_t t_debut = time(NULL);

    printf("=== BIENVENUE DANS LE MEMO-RPG ===\n");
    do {
        printf("Combien de joueurs (2 a 4) ? ");
        if(scanf("%d", &nb_joueurs) != 1) {
            vider_buffer();
            nb_joueurs = 0;
        }
    } while (nb_joueurs < 2 || nb_joueurs > 4);
    en_lice = nb_joueurs;

    for (int i = 0; i < nb_joueurs; i++) {
        printf("\n--- Configuration Joueur %d ---\n", i + 1);
        printf("Nom : ");
        scanf("%s", tab_j[i].nom);
        
        printf("Choisissez votre classe :\n");
        printf("0: Guerrier (Epee), 1: Ranger (Baton), 2: Magicien (Grimoire), 3: Voleur (Dague)\n");
        printf("Votre choix : ");
        scanf("%d", &tab_j[i].classe);

        tab_j[i].a_trouve_coffre = 0;
        tab_j[i].a_trouve_arme = 0;
        tab_j[i].nb_pas = 0;
        tab_j[i].actif = 1;
    }

    remplir_cartes(cartes);
    melanger_carte(cartes, 25);
    remplir_plateau(cartes, plateau);
    init_positions_depart(tab_j, nb_joueurs);

    while (!fini && en_lice > 0) {
        for (int i = 0; i < nb_joueurs && !fini; i++) {
            if (!tab_j[i].actif) continue;

            int tour_fini = 0;
            while (!tour_fini && !fini) {
                afficher_plateau(plateau, &tab_j[i]);
                
                printf("\n(A)vancer ou (Q)uitter la partie ? ");
                char action; scanf(" %c", &action);

                if (action == 'q' || action == 'Q') {
                    printf("%s quitte la partie.\n", tab_j[i].nom);
                    tab_j[i].actif = 0; en_lice--; tour_fini = 1;
                    continue;
                }

                int arme = choisir_arme();
                printf("Deplacement (Z=Haut, S=Bas, Q=Gauche, D=Droite) : ");
                char dir; scanf(" %c", &dir);

                int nx = tab_j[i].x, ny = tab_j[i].y;
                if(dir=='z'||dir=='Z') ny--; else if(dir=='s'||dir=='S') ny++;
                else if(dir=='q'||dir=='Q') nx--; else if(dir=='d'||dir=='D') nx++;

                if (nx < 0 || nx >= 5 || ny < 0 || ny >= 5) {
                    printf("Mur ! Impossible d'aller par la.\n");
                    tour_fini = 1;
                } else {
                    tab_j[i].x = nx; tab_j[i].y = ny;
                    tab_j[i].nb_pas++;
                    plateau[ny][nx].visible = 1;
                    char type_case = plateau[ny][nx].type;
                    printf("Case revelee : [ %c ]\n", type_case);

                    // --- ACTIONS CASES ELEMENTS ---
                    if (type_case == 'B' || type_case == 'Z' || type_case == 'T' || type_case == 'H') {
                        if (resoudre_combat(arme, type_case) == DEFAITE) {
                            tab_j[i].x = tab_j[i].x_dep; tab_j[i].y = tab_j[i].y_dep;
                            for(int r=0; r<5; r++) for(int c=0; c<5; c++) plateau[r][c].visible = 0;
                            tour_fini = 1;
                        }
                    } 
                    else if (type_case == 'P') {
                        logique_portail(&tab_j[i].x, &tab_j[i].y);
                        plateau[tab_j[i].y][tab_j[i].x].visible = 1;
                    } 
                    else if (type_case == 'M') {
                        logique_totem(plateau, &tab_j[i].x, &tab_j[i].y, tab_j[i].x_dep, tab_j[i].y_dep);
                        melanger_carte(cartes, 25);
                        remplir_plateau(cartes, plateau);
                        tour_fini = 1;
                    } 
                    else {
                        char arme_recherche = ' ';
                        if (tab_j[i].classe == 0) arme_recherche = 'E';
                        else if (tab_j[i].classe == 1) arme_recherche = 'F';
                        else if (tab_j[i].classe == 2) arme_recherche = 'G';
                        else if (tab_j[i].classe == 3) arme_recherche = 'D';

                        if(verifier_victoire(&tab_j[i].a_trouve_coffre, &tab_j[i].a_trouve_arme, type_case, arme_recherche)) {
                            printf("\n******************************************\n");
                            printf("    BRAVO, LA QUETE EST FINIE !        \n");
                            printf("    LE VAINQUEUR EST : %s                   \n", tab_j[i].nom);
                            printf("******************************************\n");
                            strcpy(gagnant_nom, tab_j[i].nom);
                            fini = 1;
                        }
                    }
                }
            }
        }
    }

    // --- ENREGISTREMENT ET COMPILATION DES STATISTIQUES ---
    time_t t_fin = time(NULL);
    int duree = (int)difftime(t_fin, t_debut);

    char noms_partie[4][MAX_NOM];
    int cases_partie[4];
    for(int i=0; i<nb_joueurs; i++) {
        strcpy(noms_partie[i], tab_j[i].nom);
        cases_partie[i] = tab_j[i].nb_pas;
    }

    maj_historique(historique, &nb_historique, noms_partie, nb_joueurs, gagnant_nom, cases_partie);
    sauvegarder_historique(historique, nb_historique);

    // --- ÉCRANS DE FIN (Fichiers d'historique C) ---
    int minutes = duree / 60;
    int secondes = duree % 60;
    printf("\n======= FIN DE PARTIE =======\n");
    printf("Vainqueur : %s\n", (strlen(gagnant_nom) > 0) ? gagnant_nom : "Aucun");
    printf("Duree : %02d min %02d sec\n", minutes, secondes);

    afficher_resume_partie(noms_partie, nb_joueurs, gagnant_nom, cases_partie);
    afficher_classement(historique, nb_historique);

    return 0;
}
