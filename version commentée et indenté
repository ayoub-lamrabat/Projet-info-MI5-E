/*
 * afficher_statut_joueur
 * Affiche sur une seule ligne le résumé d'un joueur :
 * son numéro, son nom, sa classe, s'il a le coffre, s'il a son arme,
 * et le nombre de cases parcourues. Si le joueur a quitté, affiche [QUITTE].
 * Chaque joueur a une couleur différente pour le distinguer facilement.
 */
void afficher_statut_joueur(JoueurEnJeu *j, int idx) {
    // Chaque joueur a sa propre couleur : J1=Cyan, J2=Jaune, J3=Vert, J4=Magenta
    char *couleurs[4] = { CYAN, JAUNE, VERT, MAGENTA };
    printf(GRAS "%s  J%d: %-12s" RESET, couleurs[idx], idx + 1, j->nom);
    if (j->classe == 0) {
        printf("Guerrier ");
    } else if (j->classe == 1) {
        printf("Ranger   ");
    } else if (j->classe == 2) {
        printf("Magicien ");
    } else if (j->classe == 3) {
        printf("Voleur   ");
    }
    printf("| Coffre: ");
    if (j->a_trouve_coffre) {
       printf(VERT "OUI" RESET);
   }else {
      printf(ROUGE "NON" RESET);
}
    printf(" | Arme: ");
    if (j->a_trouve_arme) {
      printf(VERT "OUI" RESET);
   }else {
      printf(ROUGE "NON" RESET);
}
    printf(" | Pas: %d", j->nb_pas);
    if (!j->actif) {
        printf(ROUGE " [QUITTE]" RESET);
    }
    printf("\n");
}

/*
 * afficher_plateau
 * Efface l'écran et affiche l'état complet du jeu :
 *   - Le titre du jeu
 *   - Le statut de tous les joueurs (nom, classe, coffre, arme, pas)
 *   - La légende des symboles
 *   - Le donjon 5x5 avec les cases cachées ("~~~"), révélées ou occupées par un joueur
 *   - Les zones de départ Nord et Sud (hors plateau) si des joueurs y attendent
 *
 * Les cases cachées s'affichent "~~~". Les cases révélées montrent leur contenu.
 * Si un joueur est sur une case, on affiche "J1", "J2" etc. à la place du contenu.
 */
void afficher_plateau(Case plateau[TAILLE][TAILLE], JoueurEnJeu tab_j[], int nb_joueurs, int idx_actuel) {
    int i, j, k;
    JoueurEnJeu *j_actuel = &tab_j[idx_actuel];
    char *couleurs[4] = { CYAN, JAUNE, VERT, MAGENTA };
    effacer_ecran();
    // En-tête du jeu
    printf(CYAN GRAS "  +===========================================+\n" RESET);
    printf(CYAN GRAS "  |" RESET BLANC GRAS "           MEMO-RPG  -  LE DONJON           " CYAN GRAS "|\n" RESET);
    printf(CYAN GRAS "  +===========================================+\n\n" RESET);
    for (k = 0; k < nb_joueurs; k++) {
        printf("  ");
        afficher_statut_joueur(&tab_j[k], k);
    }
    printf("\n");
    printf(GRAS "  >> Tour de : " RESET);
    printf(JAUNE GRAS "%s\n\n" RESET, j_actuel->nom);
    printf("  Legende : ");
    printf(ROUGE " Bs" RESET "=Basilic ");
    printf(ROUGE " Zm" RESET "=Zombie ");
    printf(ROUGE " Tr" RESET "=Troll ");
    printf(ROUGE " Hp" RESET "=Harpie | ");
    printf(JAUNE " Co" RESET "=Coffre ");
    printf(VERT " Ep/Bt/Gr/Dg" RESET "=Armes | ");
    printf(MAGENTA " Po" RESET "=Portail ");
    printf(MAGENTA " To" RESET "=Totem\n\n");
    // Affichage des numéros de colonnes au-dessus du donjon.
    printf("        ");
    for (j = 0; j < TAILLE; j++) {
        printf(GRAS "  %d  " RESET, j);
    }
    printf("\n");
    /*
     * Affichage des joueurs situés au nord du donjon.
     * Ils sont hors du plateau : leur position est y = -1.
     */
    printf("        ");
    for (j = 0; j < TAILLE; j++) {
        int joueur_ici = -1;
        for (k = 0; k < nb_joueurs; k++) {
            if (tab_j[k].actif && tab_j[k].y == -1 && tab_j[k].x == j) {
                joueur_ici = k;
                break;
            }
        }
        if (joueur_ici != -1) {
            printf(GRAS "%s[J%d] " RESET, couleurs[joueur_ici], joueur_ici + 1);
        } else {
            printf("     ");
        }
    }
    printf("\n");
    // Ligne de bordure supérieure du donjon
    printf("      +");
    for (j = 0; j < TAILLE; j++) {
        printf("-----");

        if (j < TAILLE - 1) {
            printf("+");
        }
    }
    printf("+\n");
    // Affichage ligne par ligne du donjon (lignes 0 à 4)
    for (i = 0; i < TAILLE; i++) {
        printf("  " GRAS "%d" RESET "    |", i); // Numéro de la ligne
        for (j = 0; j < TAILLE; j++) {
            // On cherche si un joueur actif se trouve sur cette case
            int joueur_ici = -1;
            for (k = 0; k < nb_joueurs; k++) {
                if (tab_j[k].actif && tab_j[k].y == i && tab_j[k].x == j) {
                    joueur_ici = k;
                    break;
                }
            }
            if (joueur_ici != -1) {
                // Un joueur est sur cette case : on affiche son numéro coloré
                printf(GRAS "%s J%d  " RESET, couleurs[joueur_ici], joueur_ici + 1);
            } else if (plateau[i][j].visible == 1) {
                // La case a été révélée : on affiche son contenu avec la bonne couleur
                char t = plateau[i][j].type;
                switch (t) {
                    case 'B': printf(ROUGE   " Bs  " RESET); break; // Basilic
                    case 'Z': printf(ROUGE   " Zm  " RESET); break; // Zombie
                    case 'T': printf(ROUGE   " Tr  " RESET); break; // Troll
                    case 'H': printf(ROUGE   " Hp  " RESET); break; // Harpie
                    case 'E': printf(VERT    " Ep  " RESET); break; // Épée de feu
                    case 'F': printf(VERT    " Bt  " RESET); break; // Bâton familier
                    case 'G': printf(VERT    " Gr  " RESET); break; // Grimoire
                    case 'D': printf(VERT    " Dg  " RESET); break; // Dague
                    case 'C': printf(JAUNE   " Co  " RESET); break; // Coffre
                    case 'M': printf(MAGENTA " To  " RESET); break; // Totem
                    case 'P': printf(MAGENTA " Po  " RESET); break; // Portail
                    default:  printf(" [?] ");               break;
                }
            } else {
                printf(FOND_NOIR BLANC " ~~~ " RESET);
            }

            printf("|");
        }

        printf("\n");

        if (i < TAILLE - 1) {
            printf("      +");

            for (j = 0; j < TAILLE; j++) {
                printf("-----");

                if (j < TAILLE - 1) {
                    printf("+");
                }
            }

            printf("+\n");
        }
    }

    printf("      +");
    for (j = 0; j < TAILLE; j++) {
        printf("-----");

        if (j < TAILLE - 1) {
            printf("+");
        }
    }
    printf("+\n");
    /*
     * Affichage des joueurs situés au sud du donjon.
     * Ils sont hors du plateau : leur position est y = 5.
     */
    printf("        ");
    for (j = 0; j < TAILLE; j++) {
        int joueur_ici = -1;
        for (k = 0; k < nb_joueurs; k++) {
            if (tab_j[k].actif && tab_j[k].y == 5 && tab_j[k].x == j) {
                joueur_ici = k;
                break;
            }
        }
        if (joueur_ici != -1) {
            printf(GRAS "%s[J%d] " RESET, couleurs[joueur_ici], joueur_ici + 1);
        } else {
            printf("     ");
        }
    }
    printf("\n\n");
    if (j_actuel->y == -1 || j_actuel->y == 5) {
        printf(JAUNE GRAS "   POSITION ACTUELLE : " RESET
               "En attente a l'exterieur du donjon (Case [%d]).\n",
               j_actuel->x);
    }
}

/*
 * afficher_plateau_final
 * Affiche le plateau entièrement révélé à la fin de la partie,
 * pour que tous les joueurs puissent voir où se trouvaient toutes les cases.
 */
void afficher_plateau_final(Case plateau[TAILLE][TAILLE]) {
    int i, j;
    printf(CYAN GRAS "\n  Voici le contenu du donjon :\n\n" RESET);
    printf("        ");
    for (j = 0; j < TAILLE; j++) {
        printf(GRAS "  %d  " RESET, j);
    }
    printf("\n");

    printf("      +");
    for (j = 0; j < TAILLE; j++) {
        printf("-----");

        if (j < TAILLE - 1) {
            printf("+");
        }
    }
    printf("+\n");
    for (i = 0; i < TAILLE; i++) {
        printf("  " GRAS "%d" RESET "    |", i);
        for (j = 0; j < TAILLE; j++) {
            char t = plateau[i][j].type;
            switch (t) {
                case 'B': printf(ROUGE   " Bs  " RESET); break;
                case 'Z': printf(ROUGE   " Zm  " RESET); break;
                case 'T': printf(ROUGE   " Tr  " RESET); break;
                case 'H': printf(ROUGE   " Hp  " RESET); break;
                case 'E': printf(VERT    " Ep  " RESET); break;
                case 'F': printf(VERT    " Bt  " RESET); break;
                case 'G': printf(VERT    " Gr  " RESET); break;
                case 'D': printf(VERT    " Dg  " RESET); break;
                case 'C': printf(JAUNE   " Co  " RESET); break;
                case 'M': printf(MAGENTA " To  " RESET); break;
                case 'P': printf(MAGENTA " Po  " RESET); break;
                default:  printf(" [?] "); break;
            }
            printf("|");
        }
        printf("\n");
        if (i < TAILLE - 1) {
            printf("      +");
            for (j = 0; j < TAILLE; j++) {
                printf("-----");
                if (j < TAILLE - 1) {
                    printf("+");
                }
            }

            printf("+\n");
        }
    }
    printf("      +");
    for (j = 0; j < TAILLE; j++) {
        printf("-----");

        if (j < TAILLE - 1) {
            printf("+");
        }
    }
    printf("+\n\n");
}
/*
 * init_positions_depart
 * Place chaque joueur à sa position de départ autour du donjon.
 * Les positions sont aux coins du plateau pour garantir une symétrie :
 *   J1 → Nord  colonne 0  (y=-1, x=0)
 *   J2 → Sud   colonne 4  (y=5,  x=4)
 *   J3 → Nord  colonne 4  (y=-1, x=4)
 *   J4 → Sud   colonne 0  (y=5,  x=0)
 */
void init_positions_depart(JoueurEnJeu tab_j[], int nb_joueurs) {
    tab_j[0].x_dep = 0;
    tab_j[0].y_dep = -1; // J1 : Nord-Ouest
    if (nb_joueurs > 1) {
        tab_j[1].x_dep = 4;
        tab_j[1].y_dep = 5; // J2 : Sud-Est
    }
    if (nb_joueurs > 2) {
        tab_j[2].x_dep = 4;
        tab_j[2].y_dep = -1; // J3 : Nord-Est
    }
    if (nb_joueurs > 3) {
        tab_j[3].x_dep = 0;
        tab_j[3].y_dep = 5; // J4 : Sud-Ouest
    }
    // Position initiale = position de départ pour tous
    int i;
    for (i = 0; i < nb_joueurs; i++) {
        tab_j[i].x = tab_j[i].x_dep;
        tab_j[i].y = tab_j[i].y_dep;
    }
}
