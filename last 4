// AJOUT : affiche la barre de statut d'un joueur (nom, classe, objets trouvés)
// Paramètre : j = le joueur, idx = son numéro (0,1,2,3) pour la couleur
void afficher_statut_joueur(JoueurEnJeu *j, int idx) {
    // chaque joueur a une couleur différente
    char *couleurs[4];
    couleurs[0] = CYAN;
    couleurs[1] = JAUNE;
    couleurs[2] = VERT;
    couleurs[3] = MAGENTA;

    // nom du joueur en gras avec sa couleur
    printf(GRAS "%s  J%d: %-12s" RESET, couleurs[idx], idx + 1, j->nom);

    // classe du joueur
    if      (j->classe == 0) printf("Guerrier ");
    else if (j->classe == 1) printf("Ranger   ");
    else if (j->classe == 2) printf("Magicien ");
    else if (j->classe == 3) printf("Voleur   ");

    // objets trouvés
    printf("| Coffre: ");
    if (j->a_trouve_coffre) printf(VERT "OUI" RESET);
    else                    printf(ROUGE "NON" RESET);

    printf(" | Arme: ");
    if (j->a_trouve_arme) printf(VERT "OUI" RESET);
    else                  printf(ROUGE "NON" RESET);

    printf(" | Pas: %d", j->nb_pas);

    if (!j->actif) printf(ROUGE " [QUITTE]" RESET);
    printf("\n");
}

// MODIFICATION de votre afficher_plateau :
// On ajoute un paramètre tab_j[] et nb_joueurs pour pouvoir afficher
// TOUS les joueurs sur le plateau en même temps, pas seulement le joueur actif.
// On ajoute aussi les bordures et les couleurs améliorées.
void afficher_plateau(Case plateau[TAILLE][TAILLE], JoueurEnJeu tab_j[], int nb_joueurs, int idx_actuel) {
    int i, j, k;
    JoueurEnJeu *j_actuel = &tab_j[idx_actuel]; // raccourci vers le joueur actif

    effacer_ecran(); // on efface l'écran à chaque tour pour un rendu propre

    // En-tête stylisé avec couleur
    printf(CYAN GRAS "  +===========================================+\n" RESET);
    printf(CYAN GRAS "  |" RESET BLANC GRAS "          MEMO-RPG  -  LE DONJON           " CYAN GRAS "|\n" RESET);
    printf(CYAN GRAS "  +===========================================+\n\n" RESET);

    // Statut de tous les joueurs en haut (AJOUT : dans votre code on ne voyait
    // que le joueur actif, maintenant on voit tout le monde en permanence)
    for (k = 0; k < nb_joueurs; k++) {
        printf("  ");
        afficher_statut_joueur(&tab_j[k], k);
    }
    printf("\n");

    // On indique à qui c'est le tour
    printf(GRAS "  >> Tour de : " RESET);
    printf(JAUNE GRAS "%s\n\n" RESET, j_actuel->nom);

    // Légende des symboles
    printf("  Legende : ");
    printf(ROUGE " Bs" RESET "=Basilic ");
    printf(ROUGE " Zm" RESET "=Zombie ");
    printf(ROUGE " Tr" RESET "=Troll ");
    printf(ROUGE " Hp" RESET "=Harpie | ");
    printf(JAUNE " Co" RESET "=Coffre ");
    printf(VERT " Ep/Bt/Gr/Dg" RESET "=Armes | ");
    printf(MAGENTA " Po" RESET "=Portail ");
    printf(MAGENTA " To" RESET "=Totem\n\n");

    // Numéros de colonnes
    printf("        ");
    for (j = 0; j < TAILLE; j++) {
        printf(GRAS "  %d  " RESET, j);
    }
    printf("\n");

    // Bordure haute du plateau avec des caractères de boîte Unicode
    printf("      +");
    for (j = 0; j < TAILLE; j++) {
        printf("-----");
        if (j < TAILLE - 1) printf("+");
    }
    printf("+\n");

    // Lignes du plateau
    for (i = 0; i < TAILLE; i++) {
        printf("  " GRAS "%d" RESET "   |", i); // numéro de ligne

        for (j = 0; j < TAILLE; j++) {
            // On cherche si un joueur est sur cette case
            int joueur_ici = -1;
            for (k = 0; k < nb_joueurs; k++) {
                if (tab_j[k].actif && tab_j[k].y == i && tab_j[k].x == j) {
                    joueur_ici = k;
                    break;
                }
            }

            if (joueur_ici != -1) {
                // On affiche le joueur avec sa couleur (J1, J2, J3, J4)
                char *couleurs[4];
                couleurs[0] = CYAN; couleurs[1] = JAUNE;
                couleurs[2] = VERT; couleurs[3] = MAGENTA;
                printf(GRAS "%s J%d  " RESET, couleurs[joueur_ici], joueur_ici + 1);
            } else if (plateau[i][j].visible == 1) {
                // Case révélée : on affiche son contenu
                char t = plateau[i][j].type;
                switch (t) {
                    // Les Monstres
                    case 'B': printf(ROUGE " Bs  " RESET); break; // Basilic
                    case 'Z': printf(ROUGE " Zm  " RESET); break; // Zombie
                    case 'T': printf(ROUGE " Tr  " RESET); break; // Troll
                    case 'H': printf(ROUGE " Hp  " RESET); break; // Harpie

                    // Les Armes Antiques
                    case 'E': printf(VERT  " Ep  " RESET); break; // Épée de feu
                    case 'F': printf(VERT  " Bt  " RESET); break; // Bâton
                    case 'G': printf(VERT  " Gr  " RESET); break; // Grimoire
                    case 'D': printf(VERT  " Dg  " RESET); break; // Dague

                    // Les Événements
                    case 'C': printf(JAUNE  " Co  " RESET); break; // Coffre au trésor
                    case 'M': printf(MAGENTA " To  " RESET); break; // Totem
                    case 'P': printf(MAGENTA " Po  " RESET); break; // Portail magique

                    default: printf(" [?] "); break;
                }
            } else {
                // Case cachée : brouillard de guerre
                printf(FOND_NOIR BLANC " ~~~ " RESET);
            }
            printf("|");
        }
        printf("\n");

        // Séparateur horizontal entre les lignes
        if (i < TAILLE - 1) {
            printf("      +");
            for (j = 0; j < TAILLE; j++) {
                printf("-----");
                if (j < TAILLE - 1) printf("+");
            }
            printf("+\n");
        }
    }

    // Bordure basse du plateau
    printf("      +");
    for (j = 0; j < TAILLE; j++) {
        printf("-----");
        if (j < TAILLE - 1) printf("+");
    }
    printf("+\n\n");

    // Message si le joueur est encore aux portes du plateau (hors grille)
    if (j_actuel->y < 0 || j_actuel->y >= TAILLE || j_actuel->x < 0 || j_actuel->x >= TAILLE) {
        printf(JAUNE "  Vous etes aux portes du donjon. Entrez sur le plateau !\n" RESET);
    }
}

