#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_JOUEURS 100
#define MAX_NOM 50
#define TAILLE_GRILLE 5

typedef struct {
    char nom[MAX_NOM];
    int parties;
    int victoires;
    int cases_parcourues;
} Joueur;

void vider_buffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

int lire_entier(char message[], int min, int max) {
    int valeur;

    while (1) {
        printf("%s", message);

        if (scanf("%d", &valeur) == 1) {
            vider_buffer();

            if (valeur >= min && valeur <= max)
                return valeur;
        } else {
            vider_buffer();
        }

        printf("Valeur invalide.\n");
    }
}

void lire_nom(char nom[], char message[]) {
    while (1) {
        printf("%s", message);

        fgets(nom, MAX_NOM, stdin);

        nom[strcspn(nom, "\n")] = '\0';

        if (strlen(nom) > 0)
            return;

        printf("Nom invalide.\n");
    }
}

int chercher_joueur(Joueur joueurs[], int nb_joueurs, char nom[]) {
    for (int i = 0; i < nb_joueurs; i++) {
        if (strcmp(joueurs[i].nom, nom) == 0)
            return i;
    }

    return -1;
}

int ajouter_joueur(Joueur joueurs[], int *nb_joueurs, char nom[]) {

    int pos = chercher_joueur(joueurs, *nb_joueurs, nom);

    if (pos != -1)
        return pos;

    if (*nb_joueurs >= MAX_JOUEURS) {
        printf("Historique plein.\n");
        return -1;
    }

    pos = (*nb_joueurs)++;

    strcpy(joueurs[pos].nom, nom);
    joueurs[pos].parties = 0;
    joueurs[pos].victoires = 0;
    joueurs[pos].cases_parcourues = 0;

    return pos;
}

int charger_historique(Joueur joueurs[]) {

    FILE *fichier = fopen("stats.txt", "r");

    if (fichier == NULL)
        return 0;

    int nb_joueurs = 0;
    char ligne[200];

    while (fgets(ligne, 200, fichier) && nb_joueurs < MAX_JOUEURS) {

        ligne[strcspn(ligne, "\n")] = '\0';

        if (strncmp(ligne, "Nom:", 4) == 0)
            strcpy(joueurs[nb_joueurs].nom, ligne + 5);

        else if (strncmp(ligne, "Parties:", 8) == 0)
            joueurs[nb_joueurs].parties = atoi(ligne + 9);

        else if (strncmp(ligne, "Victoires:", 10) == 0)
            joueurs[nb_joueurs].victoires = atoi(ligne + 11);

        else if (strncmp(ligne, "Cases:", 6) == 0) {
            joueurs[nb_joueurs].cases_parcourues = atoi(ligne + 7);
            nb_joueurs++;
        }
    }

    fclose(fichier);

    return nb_joueurs;
}

void sauvegarder_historique(Joueur joueurs[], int nb_joueurs) {

    FILE *fichier = fopen("stats.txt", "w");

    if (fichier == NULL) {
        printf("Erreur sauvegarde.\n");
        return;
    }

    for (int i = 0; i < nb_joueurs; i++) {

        fprintf(fichier, "Nom: %s\n", joueurs[i].nom);
        fprintf(fichier, "Parties: %d\n", joueurs[i].parties);
        fprintf(fichier, "Victoires: %d\n", joueurs[i].victoires);
        fprintf(fichier, "Cases: %d\n", joueurs[i].cases_parcourues);
        fprintf(fichier, "---\n");
    }

    fclose(fichier);
}

void maj_historique(
    Joueur historique[],
    int *nb_historique,
    char noms_partie[][MAX_NOM],
    int nb_joueurs_partie,
    char gagnant[],
    int cases_partie[]
) {

    for (int i = 0; i < nb_joueurs_partie; i++) {

        int pos = ajouter_joueur(
            historique,
            nb_historique,
            noms_partie[i]
        );

        if (pos == -1)
            continue;

        historique[pos].parties++;
        historique[pos].cases_parcourues += cases_partie[i];

        if (strcmp(noms_partie[i], gagnant) == 0)
            historique[pos].victoires++;
    }
}

int joueur_superieur(Joueur a, Joueur b) {

    if (a.victoires > b.victoires)
        return 1;

    if (a.victoires == b.victoires &&
        a.parties < b.parties)
        return 1;

    if (a.victoires == b.victoires &&
        a.parties == b.parties &&
        a.cases_parcourues > b.cases_parcourues)
        return 1;

    return 0;
}

void trier_classement(Joueur joueurs[], int nb_joueurs) {

    for (int i = 0; i < nb_joueurs - 1; i++) {

        int meilleur = i;

        for (int j = i + 1; j < nb_joueurs; j++) {

            if (joueur_superieur(joueurs[j], joueurs[meilleur]))
                meilleur = j;
        }

        if (meilleur != i) {

            Joueur temp = joueurs[i];
            joueurs[i] = joueurs[meilleur];
            joueurs[meilleur] = temp;
        }
    }
}

void afficher_classement(Joueur historique[], int nb_historique) {

    if (nb_historique == 0) {
        printf("Aucun joueur.\n");
        return;
    }

    trier_classement(historique, nb_historique);

    printf("\nCLASSEMENT\n\n");

    for (int i = 0; i < nb_historique; i++) {

        printf("%d. %s\n", i + 1, historique[i].nom);
        printf("Victoires : %d\n", historique[i].victoires);
        printf("Parties : %d\n", historique[i].parties);
        printf("Cases : %d\n\n", historique[i].cases_parcourues);
    }
}

void afficher_plateau(char plateau[TAILLE_GRILLE][TAILLE_GRILLE]) {

    printf("\nPLATEAU\n\n");

    for (int i = 0; i < TAILLE_GRILLE; i++) {

        for (int j = 0; j < TAILLE_GRILLE; j++) {
            printf(" %c ", plateau[i][j]);
        }

        printf("\n");
    }
}

int main() {

    Joueur historique[MAX_JOUEURS];

    int nb = charger_historique(historique);

    printf("%d joueur(s) charges\n", nb);

    afficher_classement(historique, nb);

    return 0;
}
