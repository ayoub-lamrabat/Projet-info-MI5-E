#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

   CONSTANTES : définissent les valeurs fixes utilisées dans le programme
 
#define MAX_JOUEURS 100      /* Nombre maximum de joueurs stockés */
#define MAX_NOM 50           /* Longueur maximale d'un nom de joueur */
#define TAILLE_GRILLE 5      /* Taille du plateau de jeu (5x5) */
#define FICHIER_STATS "stats.txt"  /* Nom du fichier pour sauvegarder les stats */

/* 
   STRUCTURE DE DONNEES : représente un joueur avec ses statistiques
 */
typedef struct {
    char nom[MAX_NOM];       /* Nom du joueur */
    int parties;             /* Nombre total de parties jouées */
    int victoires;           /* Nombre de fois où le joueur a gagné */
    int cases_parcourues;    /* Nombre total de cases parcourues */
} Joueur;

/* 
   FONCTION : vider_buffer()
   
   Objectif : nettoyer le clavier après une entrée incorrecte
   
   Explication : quand l'utilisateur tape du texte au lieu d'un nombre,
   les caractères restent dans la mémoire. Cette fonction les efface.
   
   Paramètres : aucun
   Retour : aucun */
void vider_buffer(void) {
    int c;

    while ((c = getchar()) != '\n' && c != EOF) {
        /* Lire et ignorer chaque caractère jusqu'à la fin de ligne */
    }
}

/* 
   FONCTION : enlever_retour_ligne()
   
   Objectif : supprimer le caractère de nouvelle ligne '\n' d'une chaîne
   
   Explication : quand on lit du texte avec fgets(), le '\n' (Enter) 
   est inclus. On doit le remplacer par '\0' (fin de chaîne).
   
   Paramètres :
   - texte[] : la chaîne à corriger
   
   Retour : aucun (la chaîne est modifiée directement)
 */
void enlever_retour_ligne(char texte[]) {
    int taille;

    /* strlen() compte le nombre de caractères dans la chaîne */
    taille = strlen(texte);

    /* Si la dernière lettre est '\n', on la remplace par '\0' */
    if (taille > 0 && texte[taille - 1] == '\n') {
        texte[taille - 1] = '\0';
    }
}

/* 
   FONCTION : lire_entier()
   
   Objectif : demander à l'utilisateur d'entrer un nombre entre min et max
   
   Explication : cette fonction contrôle que l'utilisateur entre bien un nombre
   et qu'il est dans l'intervalle [min, max]. Elle redemande si ce n'est pas bon.
   
   Paramètres :
   - message[] : le texte à afficher avant de lire le nombre
   - min : la valeur minimale acceptée
   - max : la valeur maximale acceptée
   
   Retour : le nombre saisi par l'utilisateur
    */
int lire_entier(char message[], int min, int max) {
    int valeur;
    int lecture_correcte;
    int nombre_valide;

    nombre_valide = 0;
    valeur = min;

    /* Boucle : tant que le nombre n'est pas correct, on redemande */
    while (nombre_valide == 0) {
        printf("%s", message);

        /* scanf lit le nombre. Elle renvoie 1 si ça a marché */
        lecture_correcte = scanf("%d", &valeur);

        if (lecture_correcte != 1) {
            /* L'utilisateur n'a pas tapé un nombre */
            printf("Erreur : il faut entrer un nombre.\n");
            vider_buffer();
        } else {
            /* Un nombre a été lu, on nettoie le clavier */
            vider_buffer();

            /* Vérifier que le nombre est dans la plage [min, max] */
            if (valeur < min || valeur > max) {
                printf("Erreur : le nombre doit etre entre %d et %d.\n", min, max);
            } else {
                /* Tout est bon ! On sort de la boucle */
                nombre_valide = 1;
            }
        }
    }

    return valeur;
}

/* 
   FONCTION : recuperer_nom()
   
   Objectif : extraire le nom d'une ligne de texte stockée dans le fichier
   
   Explication : le fichier contient des lignes comme "Nom: Alice"
   Cette fonction récupère le texte après "Nom: "
   
   Paramètres :
   - ligne[] : la ligne complète du fichier
   - nom[] : tableau où on va stocker le nom trouvé
   
   Retour : aucun (nom[] est modifié directement)
    */
void recuperer_nom(char ligne[], char nom[]) {
    int i;
    int j;

    i = 5;  /* On saute les 5 premiers caractères ("Nom: ") */
    j = 0;  /* Position où on écrit dans le tableau nom[] */

    /* Copier caractère par caractère jusqu'à la fin de la ligne */
    while (ligne[i] != '\0' && ligne[i] != '\n') {
        nom[j] = ligne[i];
        i++;
        j++;
    }

    /* Terminer la chaîne avec '\0' */
    nom[j] = '\0';
}

/* 
   FONCTION : recuperer_nombre_depuis_ligne()
   
   Objectif : extraire un nombre d'une ligne stockée dans le fichier
   
   Explication : le fichier contient des lignes comme "Parties: 5"
   Cette fonction récupère le nombre 5 après le ":"
   
   Paramètres :
   - ligne[] : la ligne complète du fichier
   
   Retour : le nombre trouvé dans la ligne
    */
int recuperer_nombre_depuis_ligne(char ligne[]) {
    char texte_nombre[20];
    int i;
    int j;
    int nombre;

    i = 0;
    j = 0;

    /* Étape 1 : trouver le caractère ':' */
    while (ligne[i] != ':' && ligne[i] != '\0') {
        i++;
    }

    /* Étape 2 : sauter le ':' et l'espace après */
    if (ligne[i] == ':') {
        i++;
    }

    if (ligne[i] == ' ') {
        i++;
    }

    /* Étape 3 : copier les chiffres dans texte_nombre */
    while (ligne[i] != '\0' && ligne[i] != '\n') {
        texte_nombre[j] = ligne[i];
        i++;
        j++;
    }

    texte_nombre[j] = '\0';

    /* atoi() transforme une chaîne en nombre */
    nombre = atoi(texte_nombre);

    return nombre;
}

/*
   FONCTION : chercher_joueur()
   
   Objectif : trouver la position d'un joueur dans le tableau
   
   Explication : on parcourt tous les joueurs et on compare les noms.
   Si on trouve une correspondance, on retourne sa position.
   
   Paramètres :
   - joueurs[] : tableau de tous les joueurs
   - nb_joueurs : nombre de joueurs dans le tableau
   - nom[] : nom du joueur à chercher
   
   Retour : position du joueur (0, 1, 2...) ou -1 s'il n'existe pas
   ======================================================================== */
int chercher_joueur(Joueur joueurs[], int nb_joueurs, char nom[]) {
    int i;
    int position;

    position = -1;  /* Par défaut, le joueur n'existe pas */

    /* Boucle : parcourir tous les joueurs */
    for (i = 0; i < nb_joueurs; i++) {
        /* strcmp() compare deux chaînes. Elle renvoie 0 si elles sont identiques */
        if (strcmp(joueurs[i].nom, nom) == 0) {
            position = i;  /* On a trouvé le joueur ! */
        }
    }

    return position;
}

/* ========================================================================
   FONCTION : ajouter_joueur_si_absent()
   
   Objectif : ajouter un nouveau joueur s'il n'existe pas déjà
   
   Explication : si le joueur existe, on retourne sa position.
   Sinon, on le crée et on augmente le nombre de joueurs.
   
   Paramètres :
   - joueurs[] : tableau de tous les joueurs
   - nb_joueurs : pointeur vers le nombre de joueurs (car on va le modifier)
   - nom[] : nom du nouveau joueur
   
   Retour : position du joueur (existant ou nouvellement créé)
   ======================================================================== */
int ajouter_joueur_si_absent(Joueur joueurs[], int *nb_joueurs, char nom[]) {
    int position;

    /* D'abord, chercher si le joueur existe */
    position = chercher_joueur(joueurs, *nb_joueurs, nom);

    /* Si le joueur n'existe pas (position == -1) */
    if (position == -1) {
        /* Vérifier qu'on ne dépasse pas le maximum de joueurs */
        if (*nb_joueurs < MAX_JOUEURS) {
            /* strcpy() copie une chaîne dans une autre */
            strcpy(joueurs[*nb_joueurs].nom, nom);
            
            /* Initialiser ses statistiques à 0 */
            joueurs[*nb_joueurs].parties = 0;
            joueurs[*nb_joueurs].victoires = 0;
            joueurs[*nb_joueurs].cases_parcourues = 0;

            position = *nb_joueurs;
            (*nb_joueurs)++;  /* Augmenter le nombre de joueurs */
        } else {
            printf("Erreur : l'historique est plein.\n");
            position = -1;
        }
    }

    return position;
}

/* ========================================================================
   FONCTION : lire_un_joueur_dans_fichier()
   
   Objectif : lire les données d'un joueur complètes depuis le fichier
   
   Explication : le fichier contient 4 lignes par joueur (nom, parties, 
   victoires, cases), suivi d'une ligne "---" qui les sépare.
   
   Paramètres :
   - fichier : fichier déjà ouvert
   - joueur : pointeur vers la structure à remplir
   
   Retour : 1 si la lecture a réussi, 0 sinon
   ======================================================================== */
int lire_un_joueur_dans_fichier(FILE *fichier, Joueur *joueur) {
    char ligne[100];
    int lecture_reussie;

    lecture_reussie = 0;

    /* Lire la ligne du nom */
    if (fgets(ligne, 100, fichier) != NULL) {
        recuperer_nom(ligne, joueur->nom);

        /* Lire la ligne des parties */
        if (fgets(ligne, 100, fichier) != NULL) {
            joueur->parties = recuperer_nombre_depuis_ligne(ligne);

            /* Lire la ligne des victoires */
            if (fgets(ligne, 100, fichier) != NULL) {
                joueur->victoires = recuperer_nombre_depuis_ligne(ligne);

                /* Lire la ligne des cases parcourues */
                if (fgets(ligne, 100, fichier) != NULL) {
                    joueur->cases_parcourues = recuperer_nombre_depuis_ligne(ligne);

                    /* Lire la ligne "---" qui sépare deux joueurs */
                    fgets(ligne, 100, fichier);

                    lecture_reussie = 1;
                }
            }
        }
    }

    return lecture_reussie;
}

/* ========================================================================
   FONCTION : charger_historique()
   
   Objectif : charger tous les joueurs depuis le fichier de sauvegarde
   
   Explication : on ouvre le fichier et on lit chaque joueur un par un
   jusqu'à la fin du fichier ou jusqu'à avoir lu MAX_JOUEURS joueurs.
   
   Paramètres :
   - joueurs[] : tableau où on va stocker les joueurs chargés
   
   Retour : nombre de joueurs chargés depuis le fichier
   ======================================================================== */
int charger_historique(Joueur joueurs[]) {
    FILE *fichier;
    int nb_joueurs;
    int lecture_reussie;

    nb_joueurs = 0;
    lecture_reussie = 1;

    /* fopen() avec "r" ouvre le fichier en lecture */
    fichier = fopen(FICHIER_STATS, "r");

    if (fichier == NULL) {
        /* Le fichier n'existe pas encore, c'est normal au premier lancement */
        nb_joueurs = 0;
    } else {
        /* Lire les joueurs un par un jusqu'à la fin du fichier */
        while (lecture_reussie == 1 && nb_joueurs < MAX_JOUEURS) {
            lecture_reussie = lire_un_joueur_dans_fichier(fichier, &joueurs[nb_joueurs]);

            if (lecture_reussie == 1) {
                nb_joueurs++;
            }
        }

        fclose(fichier);  /* Fermer le fichier */
    }

    return nb_joueurs;
}

/* ========================================================================
   FONCTION : sauvegarder_historique()
   
   Objectif : écrire tous les joueurs dans le fichier de sauvegarde
   
   Explication : on ouvre le fichier en écriture (ce qui efface l'ancien contenu)
   puis on écrit chaque joueur avec ses statistiques.
   
   Paramètres :
   - joueurs[] : tableau des joueurs à sauvegarder
   - nb_joueurs : nombre de joueurs à sauvegarder
   
   Retour : aucun
   ======================================================================== */
void sauvegarder_historique(Joueur joueurs[], int nb_joueurs) {
    FILE *fichier;
    int i;

    /* fopen() avec "w" ouvre le fichier en écriture */
    fichier = fopen(FICHIER_STATS, "w");

    if (fichier == NULL) {
        printf("Erreur : impossible d'ouvrir le fichier de sauvegarde.\n");
    } else {
        /* Écrire chaque joueur dans le fichier */
        for (i = 0; i < nb_joueurs; i++) {
            /* fprintf() est comme printf(), mais écrit dans un fichier */
            fprintf(fichier, "Nom: %s\n", joueurs[i].nom);
            fprintf(fichier, "Parties: %d\n", joueurs[i].parties);
            fprintf(fichier, "Victoires: %d\n", joueurs[i].victoires);
            fprintf(fichier, "Cases: %d\n", joueurs[i].cases_parcourues);
            fprintf(fichier, "---\n");  /* Ligne de séparation */
        }

        fclose(fichier);  /* Fermer le fichier */
    }
}

/* ========================================================================
   FONCTION : initialiser_cases_partie()
   
   Objectif : mettre à 0 le compteur de cases pour tous les joueurs
   
   Explication : avant de commencer une partie, on doit réinitialiser
   le tableau pour compter les cases parcourues pendant cette partie.
   
   Paramètres :
   - cases_partie[] : tableau à réinitialiser
   - nb_joueurs_partie : nombre de joueurs dans cette partie
   
   Retour : aucun
   ======================================================================== */
void initialiser_cases_partie(int cases_partie[], int nb_joueurs_partie) {
    int i;

    /* Mettre tous les compteurs à 0 */
    for (i = 0; i < nb_joueurs_partie; i++) {
        cases_partie[i] = 0;
    }
}

/* ========================================================================
   FONCTION : ajouter_case_parcourue()
   
   Objectif : augmenter le compteur de cases parcourues pour un joueur
   
   Explication : chaque fois qu'un joueur se déplace sur le plateau,
   on ajoute 1 à son compteur.
   
   Paramètres :
   - cases_partie[] : tableau des compteurs
   - numero_joueur : numéro du joueur (commence à 0)
   
   Retour : aucun
   ======================================================================== */
void ajouter_case_parcourue(int cases_partie[], int numero_joueur) {
    /* Augmenter le compteur de ce joueur */
    cases_partie[numero_joueur]++;
}

/* ========================================================================
   FONCTION : mettre_a_jour_historique()
   
   Objectif : mettre à jour les statistiques après la fin d'une partie
   
   Explication : on ajoute 1 au nombre de parties jouées pour tous les joueurs,
   on augmente les cases parcourues, et on ajoute 1 victoire au gagnant.
   
   Paramètres :
   - historique[] : tableau des joueurs (statistiques globales)
   - nb_historique : pointeur vers le nombre de joueurs
   - noms_partie[] : noms des joueurs qui ont participé
   - nb_joueurs_partie : nombre de joueurs dans cette partie
   - gagnant[] : nom du joueur qui a gagné
   - cases_partie[] : nombre de cases parcourues par chaque joueur
   
   Retour : aucun
   ======================================================================== */
void mettre_a_jour_historique(Joueur historique[],
                              int *nb_historique,
                              char noms_partie[][MAX_NOM],
                              int nb_joueurs_partie,
                              char gagnant[],
                              int cases_partie[]) {
    int i;
    int position;

    /* Boucle : traiter chaque joueur de la partie */
    for (i = 0; i < nb_joueurs_partie; i++) {
        /* Ajouter le joueur à l'historique s'il n'y est pas */
        position = ajouter_joueur_si_absent(historique, nb_historique, noms_partie[i]);

        if (position != -1) {
            /* Augmenter le nombre de parties jouées */
            historique[position].parties++;
            
            /* Ajouter les cases parcourues pendant cette partie */
            historique[position].cases_parcourues += cases_partie[i];

            /* Vérifier si ce joueur a gagné */
            if (strcmp(noms_partie[i], gagnant) == 0) {
                historique[position].victoires++;
            }
        }
    }
}

/* ========================================================================
   FONCTION : joueur_est_mieux_classe()
   
   Objectif : comparer deux joueurs pour savoir qui est le meilleur
   
   Explication : le critère de classement est :
   1. Le plus de victoires
   2. Si victoires égales, le moins de parties jouées
   3. Si toujours égal, le plus de cases parcourues
   
   Paramètres :
   - a : premier joueur
   - b : deuxième joueur
   
   Retour : 1 si a est mieux classé que b, 0 sinon
   ======================================================================== */
int joueur_est_mieux_classe(Joueur a, Joueur b) {
    int resultat;

    resultat = 0;

    /* Critère 1 : plus de victoires */
    if (a.victoires > b.victoires) {
        resultat = 1;
    }
    /* Critère 2 : victoires égales, moins de parties */
    else if (a.victoires == b.victoires && a.parties < b.parties) {
        resultat = 1;
    }
    /* Critère 3 : tout égal, plus de cases parcourues */
    else if (a.victoires == b.victoires &&
             a.parties == b.parties &&
             a.cases_parcourues > b.cases_parcourues) {
        resultat = 1;
    }

    return resultat;
}

/* ========================================================================
   FONCTION : echanger_joueurs()
   
   Objectif : inverser les positions de deux joueurs dans un tableau
   
   Explication : on utilise une variable temporaire pour échanger le contenu
   des deux structures de données.
   
   Paramètres :
   - a : pointeur vers le premier joueur
   - b : pointeur vers le deuxième joueur
   
   Retour : aucun
   ======================================================================== */
void echanger_joueurs(Joueur *a, Joueur *b) {
    Joueur temp;

    /* Sauvegarder le contenu de a dans temp */
    temp = *a;
    /* Copier b dans a */
    *a = *b;
    /* Copier temp dans b */
    *b = temp;
}

/* ========================================================================
   FONCTION : trier_classement()
   
   Objectif : trier les joueurs du meilleur au moins bon
   
   Explication : on utilise l'algorithme de tri par sélection.
   On trouve le meilleur joueur et on le met en première position,
   puis le deuxième meilleur, etc.
   
   Paramètres :
   - joueurs[] : tableau des joueurs à trier
   - nb_joueurs : nombre de joueurs
   
   Retour : aucun (le tableau est modifié directement)
   ======================================================================== */
void trier_classement(Joueur joueurs[], int nb_joueurs) {
    int i;
    int j;
    int meilleur;

    /* Boucle 1 : parcourir chaque position */
    for (i = 0; i < nb_joueurs - 1; i++) {
        meilleur = i;

        /* Boucle 2 : chercher le meilleur joueur parmi les restants */
        for (j = i + 1; j < nb_joueurs; j++) {
            if (joueur_est_mieux_classe(joueurs[j], joueurs[meilleur]) == 1) {
                meilleur = j;
            }
        }

        /* Si le meilleur n'est pas à la position i, l'y mettre */
        if (meilleur != i) {
            echanger_joueurs(&joueurs[i], &joueurs[meilleur]);
        }
    }
}

/* ========================================================================
   FONCTION : afficher_classement_depuis_fichier()
   
   Objectif : charger et afficher le classement depuis le fichier
   
   Explication : on charge d'abord les joueurs du fichier, puis on les affiche.
   
   Paramètres : aucun
   Retour : aucun
   ======================================================================== */
void afficher_classement_depuis_fichier(void) {
    Joueur historique[MAX_JOUEURS];
    int nb_historique;

    /* Charger les joueurs du fichier */
    nb_historique = charger_historique(historique);
    
    /* Afficher le classement */
    afficher_classement(historique, nb_historique);
}

/* ========================================================================
   FONCTION : afficher_classement()
   
   Objectif : afficher la liste des joueurs triée par classement
   
   Explication : on trie les joueurs, puis on les affiche avec leurs stats.
   
   Paramètres :
   - historique[] : tableau des joueurs
   - nb_historique : nombre de joueurs
   
   Retour : aucun
   ======================================================================== */
void afficher_classement(Joueur historique[], int nb_historique) {
    int i;

    if (nb_historique == 0) {
        printf("\nAucun joueur dans l'historique.\n");
    } else {
        /* Trier les joueurs du meilleur au moins bon */
        trier_classement(historique, nb_historique);

        /* Afficher le titre */
        printf("\nCLASSEMENT GENERAL\n");
        printf("------------------\n");

        /* Afficher chaque joueur avec ses statistiques */
        for (i = 0; i < nb_historique; i++) {
            printf("%d. %s\n", i + 1, historique[i].nom);
            printf("   Victoires : %d\n", historique[i].victoires);
            printf("   Parties : %d\n", historique[i].parties);
            printf("   Cases parcourues : %d\n", historique[i].cases_parcourues);
            printf("\n");
        }
    }
}

