#define TAILLE 5
#define RESET   "\033[0m"
#define ROUGE   "\033[31m"
#define VERT    "\033[32m"
#define JAUNE   "\033[33m"
#define BLEU    "\033[34m"
#define CYAN    "\033[36m"
#define BLANC   "\033[37m"


// Dans fichier entites.h :
typedef struct {
    char type;           // 'B' Basilic, 'Z' Zombie, 'T' Troll, 'H' Harpie, 'E' Epée, 'F' Bâton, 'D' Dague, 'G' Grimoire, 'P' Portail, 'T' Totem, 'C' Coffre.
    int visible;         // 0 = cachée (brouillard), 1 = révélée
} Case;

typedef struct {
    int x, y;            // Position actuelle
    int x_dep, y_dep;    // Position de départ
    char nom[50];
    int classe;          // 0 = Guerrier (cherche l'Épée), 1 = Ranger (cherche le Bâton), 2 = Magicien (cherche le Grimoire), 3 = Voleur (cherche la Dague)
    int a_trouve_coffre; // Au début = 0. Si un joueur tombe sur une case 'C' (Coffre), alors = 1.
    int a_trouve_arme;  
} Joueur;



//La fonction d'affichage (dans affichage.c) : Elle parcourt le plateau. Si visible vaut 0, on affiche '?'.
void afficher_plateau(Case plateau[TAILLE][TAILLE], Joueur *j_actuel) {
    // 1. En-tête stylisé avec de la couleur (Cyan)
    printf(CYAN "\n=========================================\n" RESET);
    printf(CYAN "          🧙 TOUR DE : %s 🧙\n" RESET, j_actuel->nom);
    printf(CYAN "=========================================\n" RESET);
    
    // Repères des colonnes
    printf("     0   1   2   3   4\n"); 
    printf("   ---------------------\n");

    for (int i = 0; i < TAILLE; i++) {
        printf("%d | ", i); // Index de ligne avec une barre de séparation
        
        for (int j = 0; j < TAILLE; j++) {
            
            // CAS 1 : C'est la position du joueur (Pion) 
            if (i == j_actuel->y && j == j_actuel->x) {
                printf(" 🏃 "); // Un émoji qui court pour le joueur !
            }
            
            // CAS 2 : La case est révélée, on affiche l'émoji correspondant
            else if (plateau[i][j].visible == 1) {
                char t = plateau[i][j].type;
                
                switch(t) {
                    // Les Monstres
                    case 'B': printf(" 🐍 "); break; // Basilic
                    case 'Z': printf(" 🧟 "); break; // Zombie
                    case 'T': printf(" 👹 "); break; // Troll
                    case 'H': printf(" 🦅 "); break; // Harpie
                    
                    // Les Armes Antiques
                    case 'E': printf(ROUGE " ⚔️ " RESET); break; // Épée de feu
                    case 'F': printf(VERT  " 🪄 " RESET); break; // Bâton
                    case 'G': printf(BLEU  " 📖 " RESET); break; // Grimoire
                    case 'D': printf(JAUNE " 🗡️ " RESET); break; // Dague
                    
                    // Les Événements
                    case 'C': printf(" 👑 "); break; // Coffre au trésor
                    case 'M': printf(" 🗿 "); break; // Totem
                    case 'P': printf(" 🌀 "); break; // Portail magique
                    
                    default:  printf(" [ ] "); break;
                }
            }
            // CAS 3 : Brouillard de guerre (Case cachée)
            else {
                printf(BLANC " 🧱 " RESET); // Un bloc de mur gris/blanc pour le mystère
            }
        }
        printf("\n");
    }
    printf("   ---------------------\n\n");
}


//2. Moteur de déplacement et Symétrie Radiale.
void init_positions_depart(Joueur tab_j[], int nb_joueurs) {
    // Joueur 0 (Nord - Vert). Au-dessus de la grille (x=2, y=-1)
    tab_j[0].x_dep = 2;
    tab_j[0].y_dep = -1;
   
    // Joueur 1 (Sud - Orange). En-dessous de la grille (x=2, y=5)
    if (nb_joueurs > 1) {
        tab_j[1].x_dep = 2;
        tab_j[1].y_dep = 5;
    }
   
    // Joueur 2 (Ouest - Bleu). À gauche de la grille (x=-1, y=2)
    if (nb_joueurs > 2) {
        tab_j[2].x_dep = -1;
        tab_j[2].y_dep = 2;
    }
   
    // Joueur 3 (Est - Blanc). À droite de la grille (x=5, y=2)
    if (nb_joueurs > 3) {
        tab_j[3].x_dep = 5;
        tab_j[3].y_dep = 2;
    }

    // On téléporte les joueurs sur leur case de départ externe
    for(int i = 0; i < nb_joueurs; i++) {
        tab_j[i].x = tab_j[i].x_dep;
        tab_j[i].y = tab_j[i].y_dep;
    }
}



//3. Entrées sécurisées (ZQSD). Pour éviter que le programme ne plante si l'utilisateur tape "Bonjour" au lieu de 'Z', on vide le tampon.
char recuperer_direction() {
    char choix;
    int valide = 0;
    while (!valide) {
        printf("Deplacement (Z=Haut, S=Bas, Q=Gauche, D=Droite) OU Menu (M): ");
        scanf(" %c", &choix); // (L'espace avant %c est CRUCIAL (ignore l'Entrée du tour précédent). JUSTIFICATION: Le problème : Le "Fantôme" de la touche Entrée. Quand tu demandes au joueur de taper une direction : Le joueur tape la lettre 'z'. Ensuite, il appuie sur la touche Entrée (le symbole \n en informatique) pour valider.Le souci, c'est que scanf récupère la lettre 'z', mais il laisse traîner le \n (le retour à la ligne) dans la mémoire tampon du clavier (le "buffer"). Au tour suivant : Quand ton programme arrive à nouveau sur un scanf("%c", &choix), il regarde le tampon. Il y voit le \n qui restait du tour d'avant. Il se dit : "Tiens, il y a déjà un caractère ici !". Il récupère donc le \n automatiquement sans attendre que le joueur tape quoi que ce soit. Résultat : Le programme affiche "Touche invalide" instantanément parce qu'il a cru que l'utilisateur avait tapé "Entrée" au lieu de Z, Q, S ou D. La solution : Le petit espace magique " %c".En mettant un espace juste avant le %c dans ton scanf, tu donnes une instruction très précise au langage C : "S'il te plaît, ignore tous les caractères 'blancs' (espaces, tabulations, et surtout les retours à la ligne \n) jusqu'à ce que tu trouves une vraie lettre ou un vrai chiffre." Voici ce qui se passe avec l'espace : Le \n du tour précédent est toujours là. Le scanf(" %c") arrive. Il voit le \n, il se dit : "C'est un caractère blanc, l'espace dans mon format me dit de l'ignorer". Il le jette à la poubelle.Il attend alors que l'utilisateur tape une nouvelle lettre).
       
        if (choix == 'z' || choix == 's' || choix == 'q' || choix == 'd' ||
            choix == 'Z' || choix == 'S' || choix == 'Q' || choix == 'D') {
            valide = 1;
        } else {
            printf("Touche invalide ! Recommencez.\n");
        }
    }
    return choix;
}


int demander_quitter() {
    char confirmation;
    printf("\nEtes-vous sur de vouloir quitter la partie ? (O/N) : ");
    scanf(" %c", &confirmation);
    if (confirmation == 'o' || confirmation == 'O') {
        printf("Merci d'avoir joue ! A bientot.\n");
        return 1; // Il veut quitter
    }
    return 0; // Il reste
}


//4. La Boucle de Jeu (Game Loop). C'est ici que tu orchestres tout. Voici la logique simplifiée pour gérer le tour d'un joueur.
int gerer_tour(Joueur *j, Case plateau[TAILLE][TAILLE]) {
    int tour_fini = 0;
   
    while (!tour_fini) {
        afficher_plateau(plateau, j);

        // 1. Choisir l'arme
        int arme = choisir_arme();
       
        // 2. Choisir direction
        char dir = recuperer_direction();
        if (dir == 'M' || dir == 'm') {
            return 2; // Demande de quitter
        }
        
        int next_x = j->x;
        int next_y = j->y;

        // Calculer nouvelle position
        if (dir == 'z' || dir == 'Z') next_y--;
        else if (dir == 's' || dir == 'S') next_y++;
        else if (dir == 'q' || dir == 'Q') next_x--;
        else if (dir == 'd' || dir == 'D') next_x++;

        // 3. Vérifier limites du plateau
        if (j->x == j->x_dep && j->y == j->y_dep) {  // Cas spécial : Le joueur est sur sa case de départ en dehors du plateau
            int entree_valide = 0;
            
            // On vérifie si la touche choisie pousse le joueur vers l'intérieur du plateau
            if (j->y_dep == -1 && (dir == 's' || dir == 'S')) entree_valide = 1;      // Nord doit aller vers le Bas (S)
            else if (j->y_dep == 5 && (dir == 'z' || dir == 'Z')) entree_valide = 1;  // Sud doit aller vers le Haut (Z)
            else if (j->x_dep == -1 && (dir == 'd' || dir == 'D')) entree_valide = 1; // Ouest doit aller vers la Droite (D)
            else if (j->x_dep == 5 && (dir == 'q' || dir == 'Q')) entree_valide = 1;  // Est doit aller vers la Gauche (Q)
            
            if (!entree_valide) {
                printf("Action impossible ! Vous devez entrer sur le plateau pour commencer la partie.\n");
                continue; // Relance la boucle sans changer de joueur
            }
        }
        else {           // Cas classique : Le joueur est déjà DANS le plateau, il ne doit pas en sortir
            if (next_x < 0 || next_x >= TAILLE || next_y < 0 || next_y >= TAILLE) {
                printf("Mur ! Impossible d'aller par la.\n");
                continue; // Relance la boucle sans changer de joueur
            }
        }

        // 4. Action !
        j->x = next_x;
        j->y = next_y;
        plateau[j->y][j->x].visible = 1; // On révèle la case

        // 5. Résoudre combat ou événement
        char type_case = plateau[j->y][j->x].type;
       
        // Si c'est un monstre (B, Z, T, H)
        if (type_case == 'B' || type_case == 'Z' || type_case == 'T' || type_case == 'H') {
            if (resoudre_combat(arme, type_case) == 0) { // Défaite
                printf("Vous repartez au debut...\n");
                j->x = j->x_dep;
                j->y = j->y_dep;
                for(int r=0; r<TAILLE; r++) {      // Si on meurt, on remet tout face cachée
                    for(int c=0; c<TAILLE; c++) {
                        plateau[r][c].visible = 0;
                    }
                }
                tour_fini = 1;
            }
        }
        else if (type_case == 'M') { // Totem Transmutation
            printf("Totem ! Les cartes bougent et vous rentrez chez vous...\n");
            
           // melanger_plateau(plateau); A VERIFIER
            // 2. On renvoie le joueur à sa case de départ
            j->x = j->x_dep;
            j->y = j->y_dep;

            // 3. On remet tout le plateau dans le noir (Brouillard de guerre)
            for(int r = 0; r < TAILLE; r++) {
                for(int c = 0; c < TAILLE; c++) {
                    plateau[r][c].visible = 0;
                }
            }

            tour_fini = 1; 
        }
      
        //Il y a 2 coffres sur le plateau. N'importe quel joueur peut les ramasser.
        if (type_case == 'C') {
            printf("INCROYABLE ! %s a trouve un coffre au tresor !\n", j->nom);
            j->a_trouve_coffre = 1;
            // Le tour ne s'arrête pas, le joueur peut continuer à avancer 
        }

        //2. Le Test de l'Arme Antique ('E', 'F', 'D', 'G') : C'est ici que c'est subtil : tu dois vérifier si la lettre de la case
        // correspond à la classe du joueur. Pour que ce soit propre, dans le main on attribue un numéro de classe à chaque joueur (0: Guerrier, 1: Ranger, etc.).
        else if (type_case == 'E' || type_case == 'F' || type_case == 'D' || type_case == 'G') {
            
            // On vérifie chaque cas un par un. CAS 1 : L'épée de feu (E) pour le Guerrier (0)
            if (type_case == 'E' && j->classe == 0) {
                printf("BRAVO ! Vous avez trouve l'Epee de Feu !\n");
                j->a_trouve_arme = 1;
            } 
            // CAS 2 : Le bâton de contrôle (F) pour le Ranger (1)
            else if (type_case == 'F' && j->classe == 1) {
                printf("BRAVO ! Vous avez trouve le Baton de controle !\n");
                j->a_trouve_arme = 1;
            } 
            // CAS 3 : Le grimoire interdit (G) pour le Magicien (2)
            else if (type_case == 'G' && j->classe == 2) {
                printf("BRAVO ! Vous avez trouve le Grimoire interdit !\n");
                j->a_trouve_arme = 1;
            } 
            // CAS 4 : La dague de sommeil (D) pour le Voleur (3)
            else if (type_case == 'D' && j->classe == 3) {
                printf("BRAVO ! Vous avez trouve la Dague de sommeil !\n");
                j->a_trouve_arme = 1;
            } 
            // CAS 5 : On tombe sur l'arme d'un AUTRE joueur
            else {
                printf("Vous avez trouve une arme antique... mais ce n'est pas la votre !\n");
            }
        }

        // Vérification des conditions de victoire à la fin de l'action
        if (j->a_trouve_coffre && j->a_trouve_arme) {
            return 1; 
        }
    }
    return 0;
}





















