

void remplir_cartes(char carte[25]){ // fonction pour décider quels personnages se trouvent dans le paquet de carte.
    int i;

    for(i = 0; i < 4; i++) { // on remplit les cases de 0 à 3
        carte[i]= 'B'; // 'B' correspond au monstre Basilic (il y en a 4)
    }

    for(i = 4; i < 8; i++){ // remplissage des 4 cases suivantes
        carte[i]= 'T'; // Correspond aux Trolls
    }

    for(i = 8; i < 12; i++) { // remplissage des 4 cases suivantes
        carte[i]= 'Z' ; // Zombies
    }

    for (i = 12; i < 16; i++){ // on remplit les 4 cases suivantes
        carte[i]='H'; // Correspond aux harpies
    }

    for(i = 16; i < 18; i++) { // les 2 cases suivantes pour les coffres
        carte[i]= 'C';
    }

    carte[18]='E'; // épée de feu (lettre B deja prise)
    carte[19]= 'F'; // baton familier
    carte[20]= 'D'; // dague du sommeil
    carte[21] = 'G'; // grimoire interdit
    carte[22]= 'P'; // portail magique
    carte[23]= 'M'; // totem de transmutation 
    carte[24]= 'M'; // totem de transmutation
}

void melanger_carte(char carte[], int n){ // mélange des cartes, on utilise void car c'est une action sans réponse

    for(int i = n - 1; i > 0; i--) { // on parcourt le tableau qu'on a créer depuis la fin

        int j = rand() % (i + 1); // tirage aléatoire, mélange efficacement les cartes

        char temp = carte[i];
        carte[i] = carte[j];
        carte[j] = temp; // échange des cartes sans détruire les données (chapitre tri)
    }
}

void remplir_plateau(char carte[25], char plateau[5][5]) { // remplir plateau 5x5
    int a = 0; // va nous permettre de parcourir toutes les cartes 

    for (int i = 0; i < 5; i++){ // on parcourt les 5 cartes verticalement 
        for (int j = 0; j < 5; j++){ // on parcourt les 5 cartes horizontalement 

            plateau[i][j] = carte[a]; // piocher une carte dans le tableau créer et la placer sur le plateau 
            a++; // carte suivante
        }
    }
}


#define MIROIR 3
#define TORCHE 4
#define HACHE 5
#define ARC 6 // on définit les monstres avec des nombres 

#define VICTOIRE 1
#define DEFAITE 0
#define RIEN 2

int choisir_arme() { // choix de l'arme par l'utilisateur
    int choix; // variable qui va stocker le choix de l'utilisateur


    do {
        printf("Choisissez votre arme (3 à 6) : "); 

        if(scanf("%d", &choix) != 1) { // vérifie si l'entrée est bien un entier
            while(getchar() != '\n');// vérifie si l'entrée est bien un entier
            choix = 0; // verification du scanf
        }

        if(choix < 3 || choix > 6){ // vérifie si le nombre est hors limites
            printf("Nombre invalide !\n");
        }

    } while (choix < 3 || choix > 6); // continue tant que le choix n'est pas entre 3 et 6

    return choix; // renvoie le choix valide de l'utilisateur
}


int resoudre_combat(int arme, char monstre) { // logique combat

    if(monstre == 'B') { // si le monstre est un Basilic
        if(arme == MIROIR) { // si l'arme est le miroir
            printf("Victoire contre le Basilic\n");
            return VICTOIRE; // on renvoie victoire
        } else {
            printf("Pétrifié par le Basilic\n");
            return DEFAITE; // on renvoie défaite
        }
    }

    else if(monstre == 'Z') {  // si le monstre est un Zombie
        if(arme == TORCHE) { // la torche est efficace contre les zombies
            printf("Zombie vaincu\n");
            return VICTOIRE;
        } else {
            printf("Dévoré par le Zombie\n");
            return DEFAITE;
        }
    }

    else if(monstre == 'T') { // si le monstre est un Troll
        if(arme == HACHE) { // l'arc est efficace contre la harpie
            printf("Troll vaincu\n");
            return VICTOIRE;
        } else {
            printf("Troll vous tue\n");
            return DEFAITE;
        }
    }

    else if(monstre == 'H') { // si le monstre est une Harpie
        if(arme == ARC) {
            printf("Harpie vaincue\n");
            return VICTOIRE;
        } else {
            printf("Harpie vous tue\n");
            return DEFAITE;
        }
    }

    return RIEN; // case vide ou objet
}


void logique_portail(int *joueur_x, int *joueur_y) { // fonction qui gère la téléportation du joueur via un portail


    printf("Portail Magique !\n");

    do { // boucle qui continue tant que les coordonnées sont invalides
        printf("Nouvelle ligne : "); // demande la nouvelle position en ligne
        scanf("%d", joueur_x); //  pas de & car joueur_x est déjà une adresse

        printf("Nouvelle colonne : ");  // demande la nouvelle position en colonne
        scanf("%d", joueur_y); // pas de & car joueur_y est déjà une adresse

    } while(*joueur_x < 0 || *joueur_x > 4 || *joueur_y < 0 || *joueur_y > 4); // vérifie que les coordonnées sont dans les limites du plateau (0 à 4)

    printf("Téléportation en [%d][%d]\n", *joueur_x, *joueur_y); // la nouvelle position du joueur après téléportation
}
}



void logique_totem(char plateau[5][5], int *x, int *y, int depx, int depy) {

    int cx, cy; // variables pour stocker les coordonnées de la case cible

    printf("Totem de transmutation\n");

    printf("Ligne cible : "); // demande la ligne de la case cible
    scanf("%d", &cx);// lecture de la ligne cible

    printf("Colonne cible : "); // demande la colonne de la case cible
    scanf("%d", &cy);// lecture de la colonne cible

    if(cx < 0 || cx > 4 || cy < 0 || cy > 4){
        printf("Coordonnées invalides\n");
        return;
    }

    char temp = plateau[*x][*y]; // sauvegarde la valeur actuelle du joueur dans une variable temporaire
    plateau[*x][*y] = plateau[cx][cy]; // échange la case du joueur avec la case cible
    plateau[cx][cy] = temp;  // termine l'échange

    *x = depx; // remet la position du joueur à la position de départ en ligne
    *y = depy; // remet la position du joueur à la position de départ en colonne 

    printf("Retour au départ [%d][%d]\n", *x, *y); // affiche la nouvelle position du joueur
}


int verifier_victoire(int *coffre, int *arme_trouvee, char case_actuelle, char arme_recherche){  // fonction qui vérifie les conditions de victoire 


    if(case_actuelle == 'C'){ // si la case actuelle contient un coffre
        printf("Coffre trouvé\n");
        *coffre = 1; // on indique que le coffre a été trouvé
    }

    if(case_actuelle == arme_recherche){ // si les deux conditions sont remplies
        printf("Arme trouvée\n");
        *arme_trouvee = 1; // on retourne 1 pour signaler la victoire
    }

    if(*coffre == 1 && *arme_trouvee == 1){
        printf("VICTOIRE TOTALE\n");
        return 1;
    }

    return 0; // sinon, la partie continue 
}
