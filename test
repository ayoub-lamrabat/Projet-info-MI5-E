#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// --- CONSTANTES ---
#define TAILLE 5
#define MIROIR 3
#define TORCHE 4
#define HACHE 5
#define ARC 6 

// --- STRUCTURES ---
typedef struct {
    char type;    
    int visible;  
} Case;

typedef struct {
    int x, y;            
    int x_dep, y_dep;    
    char nom[50];
    int classe;          
    int a_trouve_coffre; 
    int a_trouve_arme;   
    int actif; 
} Joueur;

// --- FONCTIONS LOGIQUES ---

void remplir_plateau(Case plateau[5][5]) {
    char cartes[25];
    int i, j, a = 0;

    // Remplissage du paquet de 25 cartes
    for(i = 0; i < 4; i++) cartes[i] = 'B'; // Basilic
    for(i = 4; i < 8; i++) cartes[i] = 'T'; // Troll
    for(i = 8; i < 12; i++) cartes[i] = 'Z'; // Zombie
    for(i = 12; i < 16; i++) cartes[i] = 'H'; // Harpie
    for(i = 16; i < 18; i++) cartes[i] = 'C'; // Coffre
    cartes[18] = 'E'; cartes[19] = 'F'; cartes[20] = 'G'; 
    cartes[21] = 'D'; cartes[22] = 'P'; cartes[23] = 'M'; cartes[24] = 'M';

    // Mélange de Fisher-Yates
    for(i = 24; i > 0; i--) {
        int r = rand() % (i + 1);
        char temp = cartes[i];
        cartes[i] = cartes[r];
        cartes[r] = temp;
    }

    // Transfert sur le plateau
    for (i = 0; i < 5; i++) {
        for (j = 0; j < 5; j++) {
            plateau[i][j].type = cartes[a++];
            plateau[i][j].visible = 0;
        }
    }
}

void afficher_plateau(Case plateau[5][5], Joueur *j, int final) {
    printf("\n      0     1     2     3     4\n");
    for (int l = 0; l < 5; l++) {
        printf("%d ", l);
        for (int c = 0; c < 5; c++) {
            if (!final && l == j->y && c == j->x) printf("[ P ] ");
            else if (plateau[l][c].visible || final) printf("[ %c ] ", plateau[l][c].type);
            else printf("[ ? ] ");
        }
        printf("\n");
    }
}

// --- PROGRAMME PRINCIPAL ---
int main() {
    srand(time(NULL));
    int nb_j, gagne = 0, en_lice;
    Joueur t[4];
    Case plateau[5][5];

    printf("=== BIENVENUE DANS LE MEMO-RPG ===\n");
    printf("Nombre de joueurs (2-4) : ");
    scanf("%d", &nb_j);
    en_lice = nb_j;

    // Positions de départ fixes
    int dx[4] = {2, 2, 0, 4};
    int dy[4] = {0, 4, 2, 2};

    for (int i = 0; i < nb_j; i++) {
        printf("\nNom Joueur %d : ", i+1); scanf("%s", t[i].nom);
        printf("Classe (0:Guerrier[E], 1:Ranger[F], 2:Mage[G], 3:Voleur[D]) : ");
        scanf("%d", &t[i].classe);
        t[i].x = dx[i]; t[i].y = dy[i];
        t[i].x_dep = dx[i]; t[i].y_dep = dy[i];
        t[i].a_trouve_arme = 0; t[i].a_trouve_coffre = 0; t[i].actif = 1;
    }

    remplir_plateau(plateau);

    while (!gagne && en_lice > 0) {
        for (int i = 0; i < nb_j && !gagne; i++) {
            if (!t[i].actif) continue;

            int tour_finit = 0;
            while (!tour_finit && !gagne) {
                printf("\n************************************");
                printf("\nTOUR DE : %s", t[i].nom);
                printf("\nInventaire : Coffre[%s] Arme[%s]", 
                       t[i].a_trouve_coffre ? "OK" : "NO", t[i].a_trouve_arme ? "OK" : "NO");
                
                afficher_plateau(plateau, &t[i], 0);

                printf("\nAction : (A)vancer ou (Q)uitter ? ");
                char action; scanf(" %c", &action);

                if (action == 'q' || action == 'Q') {
                    t[i].actif = 0; en_lice--; tour_finit = 1;
                    printf("Adieu, %s...\n", t[i].nom);
                    continue;
                }

                int arme;
                printf("Choix arme (3:Miroir, 4:Torche, 5:Hache, 6:Arc) : ");
                scanf("%d", &arme);

                printf("Direction (Z, S, Q, D) : ");
                char dir; scanf(" %c", &dir);

                int nx = t[i].x, ny = t[i].y;
                if(dir=='z'||dir=='Z') ny--; else if(dir=='s'||dir=='S') ny++;
                else if(dir=='q'||dir=='Q') nx--; else if(dir=='d'||dir=='D') nx++;

                if (nx < 0 || nx >= 5 || ny < 0 || ny >= 5) {
                    printf("\n[!] MUR ! Tour termine.\n");
                    tour_finit = 1;
                } else {
                    t[i].x = nx; t[i].y = ny;
                    plateau[ny][nx].visible = 1;
                    char type = plateau[ny][nx].type;

                    printf("\n--- REVELATION : [ %c ] ---\n", type);

                    // LOGIQUE DES MONSTRES
                    if (type == 'B' || type == 'Z' || type == 'T' || type == 'H') {
                        int ok = 0;
                        if (type == 'B' && arme == MIROIR) ok = 1;
                        else if (type == 'Z' && arme == TORCHE) ok = 1;
                        else if (type == 'T' && arme == HACHE) ok = 1;
                        else if (type == 'H' && arme == ARC) ok = 1;

                        if (ok) {
                            printf("BRAVO : Monstre vaincu ! Vous restez sur cette case.\n");
                        } else {
                            printf("DEFAITE : Le monstre vous a battu ! Retour au depart.\n");
                            t[i].x = t[i].x_dep; t[i].y = t[i].y_dep;
                            // Reset brouillard
                            for(int r=0; r<5; r++) for(int c=0; c<5; c++) plateau[r][c].visible = 0;
                            tour_finit = 1;
                        }
                    } 
                    // LOGIQUE OBJETS
                    else if (type == 'C') {
                        printf("TRESOR : Vous avez trouvé un coffre !\n");
                        t[i].a_trouve_coffre = 1;
                    } 
                    else if ((type=='E'&&t[i].classe==0)||(type=='F'&&t[i].classe==1)||
                             (type=='G'&&t[i].classe==2)||(type=='D'&&t[i].classe==3)) {
                        printf("ARME ANTIQUE : C'est la votre ! Magnifique.\n");
                        t[i].a_trouve_arme = 1;
                    }

                    // VICTOIRE ?
                    if (t[i].a_trouve_arme && t[i].a_trouve_coffre) {
                        printf("\n!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!");
                        printf("\n  VICTOIRE ECLATANTE DE %s !", t[i].nom);
                        printf("\n!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\n");
                        gagne = 1;
                    }
                }
            }
        }
    }

    printf("\n--- FIN DE LA PARTIE ---");
    afficher_plateau(plateau, &t[0], 1);
    return 0;
