/* ========================================================================
   FONCTION : afficher_fin_partie()
   
   Objectif : afficher l'écran de fin de partie avec le gagnant et la durée
   
   Explication : on affiche le nom du gagnant et on convertit la durée
   en minutes et secondes pour mieux l'afficher.
   
   Paramètres :
   - gagnant[] : nom du gagnant
   - duree_secondes : durée totale de la partie en secondes
   
   Retour : aucun
   ======================================================================== */
void afficher_fin_partie(char gagnant[], int duree_secondes) {
    int minutes;
    int secondes;

    /* Convertir les secondes en minutes + secondes restantes */
    minutes = duree_secondes / 60;
    secondes = duree_secondes % 60;

    printf("\n===========================\n");
    printf("       FIN DE PARTIE\n");
    printf("===========================\n");
    printf("Vainqueur : %s\n", gagnant);
    printf("Duree     : %02d min %02d sec\n", minutes, secondes);
    printf("===========================\n");
}

/* ========================================================================
   FONCTION : demander_rejouer()
   
   Objectif : demander à l'utilisateur s'il veut rejouer
   
   Explication : on affiche les options et on lit le choix de l'utilisateur.
   
   Paramètres : aucun
   Retour : 1 si l'utilisateur veut rejouer, 0 sinon
   ======================================================================== */
int demander_rejouer(void) {
    int choix;
    int rejouer;

    printf("\nVoulez-vous rejouer ?\n");
    printf("1. Oui, avec les memes joueurs\n");
    printf("2. Non, retour au menu\n");

    choix = lire_entier("Votre choix : ", 1, 2);

    if (choix == 1) {
        rejouer = 1;
    } else {
        rejouer = 0;
    }

    return rejouer;
}

