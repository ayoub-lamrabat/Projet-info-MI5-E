            // CORRECTION 4 : on utilise lire_entier() pour valider la classe
            tab_j[i].classe = lire_entier("  Votre choix : ", 0, 3);

            tab_j[i].a_trouve_coffre = 0;
            tab_j[i].a_trouve_arme   = 0;
            tab_j[i].nb_pas          = 0;
            tab_j[i].actif           = 1;
        }

        // =============================================
        // BOUCLE "REJOUER AVEC LES MEMES JOUEURS"
        // AJOUT : le cahier des charges demande de pouvoir rejouer
        // =============================================
        int rejouer = 1;
        while (rejouer == 1) {

            // --- Initialisation du plateau ---
            fini          = 0;
            en_lice       = nb_joueurs;
            gagnant_nom[0] = '\0'; // on remet le gagnant à vide
            t_debut       = time(NULL);

            remplir_cartes(cartes);
            melanger_carte(cartes, 25);
            remplir_plateau(cartes, plateau);
            init_positions_depart(tab_j, nb_joueurs);

            // On remet les flags de victoire à zéro pour chaque joueur
            for (i = 0; i < nb_joueurs; i++) {
                tab_j[i].a_trouve_coffre = 0;
                tab_j[i].a_trouve_arme   = 0;
                tab_j[i].nb_pas          = 0;
                tab_j[i].actif           = 1;
            }

            // =============================================
            // BOUCLE DE JEU PRINCIPALE
            // Votre code original, avec les corrections
            // =============================================
            while (fini == 0 && en_lice > 0) {
                for (i = 0; i < nb_joueurs && fini == 0; i++) {
                    if (tab_j[i].actif == 0) continue;

                    int tour_fini = 0;
                    while (tour_fini == 0 && fini == 0) {

                        // Affichage du plateau avec TOUS les joueurs visibles
                        afficher_plateau(plateau, tab_j, nb_joueurs, i);

                        printf("\n  (A)vancer ou (Q)uitter la partie ? ");
                        char action;
                        scanf(" %c", &action); // L'espace avant %c filtre l'Entrée fantôme

                        if (action == 'q' || action == 'Q') {
                            printf(ROUGE "  %s quitte la partie.\n" RESET, tab_j[i].nom);
                            tab_j[i].actif = 0;
                            en_lice--;
                            tour_fini = 1;
                            continue;
                        }

                        if (action != 'a' && action != 'A') {
                            printf(ROUGE "  Commande inconnue. Tapez A ou Q.\n" RESET);
                            continue;
                        }

                        // Étape 1 : choisir une arme
                        int arme = choisir_arme();

                        // Étape 2 : choisir une direction
                        printf("\n  Deplacement : " JAUNE "Z" RESET "=Haut  "
                               JAUNE "S" RESET "=Bas  "
                               JAUNE "Q" RESET "=Gauche  "
                               JAUNE "D" RESET "=Droite\n");
                        printf("  Votre direction : ");
                        char dir;
                        scanf(" %c", &dir); // L'espace avant %c filtre l'Entrée fantôme

                        int nx = tab_j[i].x, ny = tab_j[i].y;
                        if      (dir == 'z' || dir == 'Z') ny--;
                        else if (dir == 's' || dir == 'S') ny++;
                        else if (dir == 'q' || dir == 'Q') nx--;
                        else if (dir == 'd' || dir == 'D') nx++;
                        else {
                            printf(ROUGE "  Direction inconnue ! Utilisez Z, S, Q ou D.\n" RESET);
                            continue;
                        }

                        // Vérification sécurisée du franchissement des portes du plateau
                        if (tab_j[i].x == tab_j[i].x_dep && tab_j[i].y == tab_j[i].y_dep) {
                            int entree_valide = 0;
                            if      (tab_j[i].y_dep == -1 && (dir == 's' || dir == 'S')) entree_valide = 1;
                            else if (tab_j[i].y_dep == 5  && (dir == 'z' || dir == 'Z')) entree_valide = 1;
                            else if (tab_j[i].x_dep == -1 && (dir == 'd' || dir == 'D')) entree_valide = 1;
                            else if (tab_j[i].x_dep == 5  && (dir == 'q' || dir == 'Q')) entree_valide = 1;

                            if (entree_valide == 0) {
                                printf(ROUGE "  Impossible ! Entrez sur le plateau par la bonne direction.\n" RESET);
                                continue;
                            }
                        } else {
                            if (nx < 0 || nx >= 5 || ny < 0 || ny >= 5) {
                                printf(ROUGE "  Mur ! Impossible d'aller par la.\n" RESET);
                                continue;
                            }
                        }

                        // Application du mouvement
                        tab_j[i].x = nx;
                        tab_j[i].y = ny;
                        tab_j[i].nb_pas++;
                        plateau[ny][nx].visible = 1;
                        char type_case = plateau[ny][nx].type;

                        // --- ACTIONS SELON LA CASE REVELEE ---
                        if (type_case == 'B' || type_case == 'Z' || type_case == 'T' || type_case == 'H') {
                            if (resoudre_combat(arme, type_case) == DEFAITE) {
                                // Défaite : retour au départ + brouillard
                                tab_j[i].x = tab_j[i].x_dep;
                                tab_j[i].y = tab_j[i].y_dep;
                                cacher_plateau(plateau); // CORRECTION 7 : on utilise la fonction au lieu des 2 boucles for
                                printf(ROUGE "\n  Toutes les cases sont remises face cachee...\n" RESET);
                                printf("  Appuyez sur Entree pour continuer...");
                                vider_buffer(); getchar();
                                tour_fini = 1;
                            }
                            // Si victoire au combat, le joueur continue son tour (pas de tour_fini)
                        }
                        else if (type_case == 'P') {
                            logique_portail(&tab_j[i].x, &tab_j[i].y);
                            plateau[tab_j[i].y][tab_j[i].x].visible = 1;
                            // Le joueur continue son tour après le portail
                        }
                        else if (type_case == 'M') {
                            logique_totem(plateau, &tab_j[i].x, &tab_j[i].y, tab_j[i].x_dep, tab_j[i].y_dep);
                            // CORRECTION 8 : suppression du goto (mauvaise pratique).
                            // On remélanге et on reremplit proprement SANS toucher aux positions
                            // des AUTRES joueurs (bug de votre version originale avec goto)
                            melanger_carte(cartes, 25);
                            remplir_plateau(cartes, plateau);
                            cacher_plateau(plateau);
                            printf("  Appuyez sur Entree pour continuer...");
                            vider_buffer(); getchar();
                            tour_fini = 1; // le totem termine toujours le tour
                        }
                        else {
                            // Case : coffre, arme antique, ou autre
                            char arme_recherche = ' ';
                            if      (tab_j[i].classe == 0) arme_recherche = 'E';
                            else if (tab_j[i].classe == 1) arme_recherche = 'F';
                            else if (tab_j[i].classe == 2) arme_recherche = 'G';
                            else if (tab_j[i].classe == 3) arme_recherche = 'D';

                            if (verifier_victoire(&tab_j[i].a_trouve_coffre, &tab_j[i].a_trouve_arme, type_case, arme_recherche)) {
                                // AJOUT : écran de victoire
                                printf(VERT GRAS "\n  +==========================================+\n" RESET);
                                printf(VERT GRAS "  |   BRAVO, LA QUETE EST FINIE !            |\n" RESET);
                                printf(VERT GRAS "  |   LE VAINQUEUR EST : %-20s|\n" RESET, tab_j[i].nom);
                                printf(VERT GRAS "  +==========================================+\n\n" RESET);
                                strcpy(gagnant_nom, tab_j[i].nom);
                                fini = 1;
                            }
                        }

                        // AJOUT : détection du blocage (aucune case cachée adjacente)
                        // Le cahier des charges dit que si le joueur est bloqué, son tour s'arrête
                        if (fini == 0 && tour_fini == 0) {
                            int bloque = 1;
                            int dx[4] = {0, 0, -1, 1};
                            int dy[4] = {-1, 1, 0, 0};
                            int d;
                            for (d = 0; d < 4; d++) {
                                int vx = tab_j[i].x + dx[d];
                                int vy = tab_j[i].y + dy[d];
                                if (vx >= 0 && vx < TAILLE && vy >= 0 && vy < TAILLE
                                    && plateau[vy][vx].visible == 0) {
                                    bloque = 0;
                                    break;
                                }
                            }
                            if (bloque == 1) {
                                printf(ROUGE "\n  %s est bloque ! Aucune case cachee accessible.\n" RESET, tab_j[i].nom);
                                tab_j[i].x = tab_j[i].x_dep;
                                tab_j[i].y = tab_j[i].y_dep;
                                cacher_plateau(plateau);
                                printf("  Appuyez sur Entree pour continuer...");
                                vider_buffer(); getchar();
                                tour_fini = 1;
                            }
                        }

                    } // fin while tour_fini
                } // fin for joueurs
            } // fin while partie

            // --- Fin de partie ---
            t_fin = time(NULL);
            duree = (int)difftime(t_fin, t_debut);

            // AJOUT : on révèle tout le plateau (demandé par le cahier des charges)
            afficher_plateau_final(plateau);

            // Enregistrement des statistiques
            char noms_partie[MAX_JOUEURS][MAX_NOM];
            int  cases_partie[MAX_JOUEURS];
            for (i = 0; i < nb_joueurs; i++) {
                strcpy(noms_partie[i], tab_j[i].nom);
                cases_partie[i] = tab_j[i].nb_pas;
            }
            maj_historique(historique, &nb_historique, noms_partie, nb_joueurs, gagnant_nom, cases_partie);
            sauvegarder_historique(historique, nb_historique);

            // Écrans de fin
            afficher_resume_partie(noms_partie, nb_joueurs, gagnant_nom, cases_partie, duree);
            afficher_classement(historique, nb_historique);

            // AJOUT : menu rejouer (demandé par le cahier des charges)
            printf(CYAN "  Que souhaitez-vous faire ?\n" RESET);
            printf("  " JAUNE "[1]" RESET " Rejouer avec les memes joueurs\n");
            printf("  " JAUNE "[2]" RESET " Retour au menu principal\n");
            int choix_fin = lire_entier("  Votre choix : ", 1, 2);

            if (choix_fin == 2) {
                rejouer = 0; // on sort de la boucle rejouer
            }
            // Si choix_fin == 1, la boucle while(rejouer == 1) recommence

        } // fin while rejouer

        effacer_ecran(); // on réaffiche le menu proprement

    } // fin while quitter

    return 0;
}
