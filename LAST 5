            }
            printf("|");
        }
        printf("\n");

        if (i < TAILLE - 1) {
            printf("      +");
            for (j = 0; j < TAILLE; j++) { printf("-----"); if (j < TAILLE - 1) printf("+"); }
            printf("+\n");
        }
    }

    printf("      +");
    for (j = 0; j < TAILLE; j++) { printf("-----"); if (j < TAILLE - 1) printf("+"); }
    printf("+\n\n");

    // --- BLOC REMPLACÉ AVEC LES INDICATIONS PRÉCISES ---
